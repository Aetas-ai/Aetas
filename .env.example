# Optional form activation group. Leave all three values blank while public form
# processing is deferred. Configure all three together before enabling forms.

# Generate a unique value of at least 32 characters for each environment.
FORM_CSRF_SECRET=

# HTTPS endpoint that accepts the authenticated JSON delivery contract.
FORM_DELIVERY_URL=

# Bearer token shared only with the approved delivery endpoint.
FORM_DELIVERY_BEARER_TOKEN=
