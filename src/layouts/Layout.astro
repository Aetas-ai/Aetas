---
import { ClientRouter } from 'astro:transitions';
import BobAssistant from '../components/BobAssistant';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePillar?: 'ai' | 'security' | 'managed-it' | 'none';
  noIndex?: boolean;
}

const {
  title,
  description = 'Aetas Global Innovation - Human Led AI, MXDR, Offensive Security, managed IT, and Business Processes services.',
  activePillar = 'none',
  noIndex = false,
} = Astro.props;

const brandName = 'Aetas Global Innovation';
const pageTitle = title.includes(brandName) ? title : `${title} | ${brandName}`;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ?? Astro.url.origin;
const canonicalUrl = new URL(currentPath, siteUrl);
const organizationUrl = new URL('/', siteUrl);
const logoUrl = new URL('/aetasIcon.webp', siteUrl);
const socialImageUrl = new URL('/aetasBrand.webp', siteUrl);
const robotsContent = noIndex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${organizationUrl}#organization`,
      name: brandName,
      alternateName: ['AGI', 'Aetas.ai'],
      url: organizationUrl.toString(),
      logo: {
        '@type': 'ImageObject',
        url: logoUrl.toString(),
        width: 512,
        height: 512,
      },
      email: 'info@aetasglobal.com',
      description:
        'Aetas Global Innovation provides Business Process AI Assimilation, MXDR, Offensive Security, managed IT, Help Desk as a Service, and Product Support as a Service.',
      knowsAbout: [
        'AI workflow automation',
        'Business Process AI Assimilation',
        'Managed Extended Detection and Response',
        'Offensive Security',
        'Managed IT services',
        'IT helpdesk services',
        'Business Processes operations',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${organizationUrl}#website`,
      url: organizationUrl.toString(),
      name: brandName,
      alternateName: 'Aetas.ai',
      publisher: { '@id': `${organizationUrl}#organization` },
      inLanguage: 'en',
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl.toString(),
      name: pageTitle,
      description,
      isPartOf: { '@id': `${organizationUrl}#website` },
      about: { '@id': `${organizationUrl}#organization` },
      inLanguage: 'en',
    },
  ],
};

const navLinkBase = 'relative px-3.5 py-2 rounded-full text-sm font-semibold transition-all duration-200 hover:bg-white/7 hover:text-white hover:shadow-lg hover:shadow-black/10 focus:outline-none focus:ring-2 focus:ring-white/20';
const isActivePath = (href: string) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
const routeLink = (href: string) =>
  `${navLinkBase} ${isActivePath(href) ? 'bg-white/10 text-white ring-1 ring-white/15' : 'text-gray-300'}`;
const pillarLink = (pillar: 'ai' | 'security' | 'managed-it', activeClass: string) =>
  `${navLinkBase} ${activePillar === pillar ? activeClass : 'text-gray-300'}`;
const mobileLink = (href: string, activeClass = 'bg-white/8 text-white border-white/10') =>
  `flex items-center justify-between px-3 py-3 rounded-xl border transition-all hover:bg-white/5 hover:translate-x-1 ${
    isActivePath(href) ? activeClass : 'border-transparent text-gray-300 hover:text-white'
  }`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/webp" href="/aetasIcon.webp" sizes="512x512" />
    <link rel="shortcut icon" type="image/webp" href="/aetasIcon.webp" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={brandName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <ClientRouter />
  </head>
  <body class="bg-brand-bg text-gray-100 font-sans antialiased overflow-x-hidden min-h-screen flex flex-col selection:bg-indigo-500/30 selection:text-white">
    <div id="site-loading-overlay" class="site-loading-overlay" hidden aria-hidden="true">
      <div class="site-loading-content" role="status" aria-live="polite" aria-atomic="true">
        <div class="site-loading-mark" aria-hidden="true">
          <span class="site-loading-ring site-loading-ring-outer"></span>
          <span class="site-loading-ring site-loading-ring-inner"></span>
          <img
            class="site-loading-bob"
            src="/bob.webp"
            alt=""
            width="266"
            height="300"
            loading="eager"
            decoding="async"
            fetchpriority="low"
          />
        </div>
        <p>Loading AGI</p>
        <div class="site-loading-progress" aria-hidden="true">
          <span class="site-loading-progress-fill"></span>
        </div>
        <span data-site-loading-message>Preparing the website</span>
      </div>
    </div>

    <script is:inline>
      (() => {
        if (window.__agiSiteLoaderReady) return;
        window.__agiSiteLoaderReady = true;

        const showDelay = 650;
        const minimumVisibleTime = 220;
        const fadeDuration = 160;
        let showTimer;
        let hideTimer;
        let concealTimer;
        let shownAt = 0;
        let initialPagePending = document.readyState !== 'complete';

        const getOverlay = () => document.getElementById('site-loading-overlay');
        const clearTimer = (timer) => {
          if (timer) window.clearTimeout(timer);
        };

        const beginLoading = (message = 'Loading page') => {
          clearTimer(showTimer);
          clearTimer(hideTimer);
          clearTimer(concealTimer);

          showTimer = window.setTimeout(() => {
            const overlay = getOverlay();
            if (!overlay) return;

            const messageElement = overlay.querySelector('[data-site-loading-message]');
            if (messageElement) messageElement.textContent = message;

            overlay.hidden = false;
            overlay.classList.remove('is-completing');
            overlay.setAttribute('aria-hidden', 'false');
            document.querySelector('main')?.setAttribute('aria-busy', 'true');
            document.documentElement.dataset.siteLoading = 'true';
            shownAt = performance.now();

            window.requestAnimationFrame(() => overlay.classList.add('is-visible'));
          }, showDelay);
        };

        const endLoading = () => {
          clearTimer(showTimer);
          clearTimer(hideTimer);

          const overlay = getOverlay();
          if (!overlay || overlay.hidden) {
            document.querySelector('main')?.removeAttribute('aria-busy');
            delete document.documentElement.dataset.siteLoading;
            return;
          }

          const visibleFor = performance.now() - shownAt;
          const remainingTime = Math.max(160, minimumVisibleTime - visibleFor);

          overlay.classList.add('is-completing');

          hideTimer = window.setTimeout(() => {
            overlay.classList.remove('is-visible');
            overlay.setAttribute('aria-hidden', 'true');
            document.querySelector('main')?.removeAttribute('aria-busy');
            delete document.documentElement.dataset.siteLoading;

            concealTimer = window.setTimeout(() => {
              if (!overlay.classList.contains('is-visible')) {
                overlay.hidden = true;
                overlay.classList.remove('is-completing');
              }
            }, fadeDuration);
          }, remainingTime);
        };

        if (initialPagePending) {
          beginLoading('Preparing the website');
          window.addEventListener('load', () => {
            initialPagePending = false;
            endLoading();
          }, { once: true });
        }

        document.addEventListener('astro:before-preparation', () => beginLoading());
        document.addEventListener('astro:after-preparation', endLoading);
        document.addEventListener('astro:page-load', () => {
          if (!initialPagePending) endLoading();
        });
        window.addEventListener('pageshow', () => {
          if (document.readyState === 'complete') {
            initialPagePending = false;
            endLoading();
          }
        });
      })();
    </script>

    <header class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-white/5 bg-brand-bg/75 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-20 flex items-center justify-between">
        <a href="/" class="flex h-12 w-[8.75rem] shrink-0 items-center justify-start rounded-md transition-[opacity,filter] duration-200 hover:opacity-90 hover:drop-shadow-[0_8px_18px_rgba(255,255,255,0.12)] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30 sm:h-14 sm:w-[12rem]" aria-label="Aetas Global Innovation home">
          <img src="/aetasBrand.webp" alt="Aetas Global Innovation" width="720" height="238" class="h-full w-full object-contain object-left" decoding="async" />
        </a>

        <nav class="hidden lg:flex items-center gap-1 rounded-full border border-white/8 bg-white/[0.025] p-1 shadow-2xl shadow-black/20" aria-label="Primary navigation">
          <a href="/" class={routeLink('/')}>Home</a>
          <a href="/ai" class={pillarLink('ai', 'bg-indigo-500/12 text-indigo-300 ring-1 ring-indigo-400/25')}>AI &amp; Automation</a>
          <a href="/security" class={pillarLink('security', 'bg-sky-500/12 text-sky-300 ring-1 ring-sky-400/25')}>Cybersecurity</a>
          <a href="/managed-it" class={pillarLink('managed-it', 'bg-amber-500/12 text-amber-300 ring-1 ring-amber-400/25')}>Managed IT</a>
          <a href="/work" class={routeLink('/work')}>Work</a>
          <a href="/partners" class={routeLink('/partners')}>Partners</a>
          <a href="/about" class={routeLink('/about')}>About</a>
          <a href="/resources" class={routeLink('/resources')}>Resources</a>
        </nav>

        <div class="hidden lg:flex items-center gap-4">
          <a href="/contact" class={`px-5 py-2.5 rounded-full text-sm font-bold transition-all shadow-lg active:scale-95 ${isActivePath('/contact') ? 'bg-indigo-500 text-white shadow-indigo-500/20' : 'bg-white text-black hover:bg-white/90 shadow-white/5 hover:shadow-white/15'}`}>
            Talk to AGI
          </a>
        </div>

        <button id="mobile-menu-btn" class="lg:hidden rounded-xl border border-white/10 bg-white/[0.03] p-2 text-gray-400 hover:bg-white/5 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/20" aria-label="Toggle menu" aria-controls="mobile-menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-16 6h16"></path>
          </svg>
        </button>
      </div>
    </header>

    <div id="mobile-menu-overlay" class="lg:hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[140] opacity-0 pointer-events-none transition-opacity duration-300"></div>

    <div id="mobile-menu" class="lg:hidden fixed inset-y-0 right-0 w-[min(20rem,calc(100vw-1rem))] max-w-[calc(100vw-1rem)] bg-brand-bg/95 backdrop-blur-2xl border-l border-white/10 z-[150] p-6 flex flex-col justify-between transform translate-x-full transition-transform duration-300 ease-in-out shadow-2xl overflow-x-hidden overflow-y-auto overscroll-contain select-none [view-transition-name:none]">
      <div>
        <div class="flex items-center justify-between mb-8 pb-4 border-b border-white/5">
          <a href="/" class="flex h-11 w-36 items-center justify-start rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30" aria-label="Aetas Global Innovation home">
            <img src="/aetasBrand.webp" alt="Aetas Global Innovation" width="720" height="238" class="h-full w-full object-contain object-left" decoding="async" />
          </a>
          <button id="mobile-menu-close" class="p-2 text-gray-400 hover:text-white rounded-lg hover:bg-white/5 transition-all focus:outline-none" aria-label="Close menu">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mb-2 px-3">Navigation</span>
          <a href="/" class={mobileLink('/')}>
            <span class="text-sm font-medium">Home</span>
            <span class="text-[9px] font-bold text-gray-400 bg-white/5 border border-white/10 px-2 py-0.5 rounded-md">Landing</span>
          </a>

          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mt-6 mb-2 px-3">AGI Services</span>
          <a href="/ai" class={mobileLink('/ai', 'bg-indigo-500/10 text-indigo-300 border-indigo-400/20')}>
            <span class="text-sm font-medium">AI &amp; Automation</span>
            <span class="text-[9px] font-bold text-indigo-400/80 bg-indigo-500/10 border border-indigo-500/20 px-2 py-0.5 rounded-md">Human Led AI</span>
          </a>
          <a href="/security" class={mobileLink('/security', 'bg-sky-500/10 text-sky-300 border-sky-400/20')}>
            <span class="text-sm font-medium">Cybersecurity</span>
            <span class="text-[9px] font-bold text-sky-400/80 bg-sky-500/10 border border-sky-500/20 px-2 py-0.5 rounded-md">MSSP</span>
          </a>
          <a href="/managed-it" class={mobileLink('/managed-it', 'bg-amber-500/10 text-amber-300 border-amber-400/20')}>
            <span class="text-sm font-medium">Managed IT</span>
            <span class="text-[9px] font-bold text-amber-500/80 bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 rounded-md">MSP</span>
          </a>

          <span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest block mt-6 mb-2 px-3">Company & Resources</span>
          <a href="/work" class={mobileLink('/work')}>Selected Work</a>
          <a href="/partners" class={mobileLink('/partners')}>Partners</a>
          <a href="/about" class={mobileLink('/about')}>About</a>
          <a href="/resources" class={mobileLink('/resources')}>Resources</a>
        </nav>
      </div>

      <div class="mt-auto pt-6 border-t border-white/5 flex flex-col gap-4">
        <a href="mailto:info@aetasglobal.com" class="text-xs text-gray-400 hover:text-white transition-colors px-3">info@aetasglobal.com</a>
        <a href="/contact" class={`w-full py-3.5 rounded-xl font-bold text-center block transition-all shrink-0 hover:scale-[1.02] active:scale-[0.98] ${isActivePath('/contact') ? 'bg-indigo-500 text-white' : 'bg-white text-black hover:bg-white/90'}`}>
          Talk to AGI
        </a>
      </div>
    </div>

    <main class="min-w-0 w-full max-w-full flex-grow pt-20">
      <slot />
    </main>

    <footer class="border-t border-white/5 bg-black/40 py-16">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-5 gap-12">
        <div class="md:col-span-2">
          <a href="/" class="mb-6 inline-flex h-16 w-52 items-center justify-center rounded-md transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30" aria-label="Aetas Global Innovation home">
            <img src="/aetasBrand.webp" alt="Aetas Global Innovation" width="720" height="238" class="h-full w-full object-contain" loading="lazy" decoding="async" />
          </a>
          <p class="text-gray-400 text-sm max-w-sm mb-6 leading-relaxed">
            Aetas.ai is the digital home of Aetas Global Innovation. AGI provides AI and automation, cybersecurity, and managed IT services for organizations that need practical expertise and accountable delivery.
          </p>
          <div class="text-gray-500 text-xs">&copy; {new Date().getFullYear()} Aetas Global Innovation. All rights reserved.</div>
        </div>

        <div>
          <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4 font-display">Services</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/ai" class="hover:text-indigo-400 transition-colors">AI &amp; Automation</a></li>
            <li><a href="/security" class="hover:text-sky-400 transition-colors">Cybersecurity</a></li>
            <li><a href="/managed-it" class="hover:text-amber-500 transition-colors">Managed IT</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4 font-display">Resources</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/work" class="hover:text-white transition-colors">Selected Work</a></li>
            <li><a href="/partners" class="hover:text-white transition-colors">Technology Partners</a></li>
            <li><a href="/resources" class="hover:text-white transition-colors">Insights & Intel</a></li>
            <li><a href="/operations-readiness-brief" class="hover:text-white transition-colors">AGI Readiness Brief</a></li>
            <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4 font-display">Legal</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/legal/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
            <li><a href="/legal/terms" class="hover:text-white transition-colors">Terms of Service</a></li>
            <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>
    </footer>

    <BobAssistant client:idle={{ timeout: 1200 }} transition:persist />

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let revealObserver: IntersectionObserver | undefined;

      const updateHeader = () => {
        const header = document.querySelector('header');
        const shouldCompact = window.scrollY > 100;
        header?.classList.toggle('bg-brand-bg/95', shouldCompact);
        header?.classList.toggle('shadow-lg', shouldCompact);
        header?.classList.toggle('shadow-black/25', shouldCompact);
        header?.classList.toggle('bg-brand-bg/75', !shouldCompact);
      };

      const initAnimations = () => {
        revealObserver?.disconnect();
        if (reduceMotion) return;

        const targets: Element[] = [];
        const prepare = (element: Element, direction: string, delay = 0) => {
          const htmlElement = element as HTMLElement;
          htmlElement.classList.add('agi-reveal', `agi-reveal-${direction}`);
          htmlElement.style.setProperty('--agi-reveal-delay', `${delay}ms`);
          targets.push(element);
        };

        document.querySelectorAll('[data-reveal]').forEach((element) => prepare(element, 'up'));
        document.querySelectorAll('[data-reveal-left]').forEach((element) => prepare(element, 'left'));
        document.querySelectorAll('[data-reveal-right]').forEach((element) => prepare(element, 'right'));
        document.querySelectorAll('[data-reveal-group]').forEach((group) => {
          Array.from(group.children).forEach((element, index) => prepare(element, 'up', index * 70));
        });
        document.querySelectorAll('[data-brand-reveal-group]').forEach((group) => {
          group.querySelectorAll('[data-brand-reveal-item]').forEach((element, index) => prepare(element, 'pop', index * 90));
        });

        revealObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('agi-reveal-visible');
            observer.unobserve(entry.target);
          });
        }, { rootMargin: '0px 0px -12% 0px', threshold: 0.04 });

        targets.forEach((target) => revealObserver?.observe(target));
      };

      const initMobileMenu = () => {
        const btn = document.getElementById('mobile-menu-btn');
        const overlay = document.getElementById('mobile-menu-overlay');
        const menu = document.getElementById('mobile-menu');
        const closeBtn = document.getElementById('mobile-menu-close');

        const openMenu = () => {
          menu?.classList.remove('translate-x-full');
          menu?.classList.add('translate-x-0');
          overlay?.classList.remove('opacity-0', 'pointer-events-none');
          overlay?.classList.add('opacity-100', 'pointer-events-auto');
          document.body.classList.add('overflow-hidden');
        };

        const closeMenu = () => {
          menu?.classList.add('translate-x-full');
          menu?.classList.remove('translate-x-0');
          overlay?.classList.add('opacity-0', 'pointer-events-none');
          overlay?.classList.remove('opacity-100', 'pointer-events-auto');
          document.body.classList.remove('overflow-hidden');
        };

        if (btn) btn.onclick = openMenu;
        if (closeBtn) closeBtn.onclick = closeMenu;
        if (overlay) (overlay as HTMLElement).onclick = closeMenu;
        menu?.querySelectorAll('a').forEach((link) => {
          (link as HTMLElement).onclick = closeMenu;
        });
      };

      document.addEventListener('astro:page-load', () => {
        updateHeader();
        initAnimations();
        initMobileMenu();
      });

      document.addEventListener('astro:before-preparation', () => {
        revealObserver?.disconnect();
      });

      document.addEventListener('astro:after-swap', () => {
        document.body.classList.remove('overflow-hidden');
      });
      window.addEventListener('scroll', updateHeader, { passive: true });
    </script>
  </body>
</html>
