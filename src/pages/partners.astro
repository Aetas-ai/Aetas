---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Partners & Alliances - Reseller Portfolio" description="Browse Aetas Global Innovation technology partnerships, cloud and AI platforms, security alliances, and reseller product portfolio.">
  <PageHero
    eyebrow="Technology ecosystem"
    title="Platforms, procurement, and implementation support."
    description="Explore the cloud, AI, and cybersecurity technology categories Aetas can evaluate and support. Public partner tiers and certifications remain subject to verification."
    compact
    primaryLabel="Discuss a technology need"
    primaryHref="/contact?intent=partners"
  />

  <section class="overflow-hidden px-6 py-20 sm:py-24">

    <!-- Category 1: Cloud & AI -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="border-b border-white/5 pb-4 mb-8">
        <h2 class="text-xl font-display font-bold text-white uppercase tracking-wider">Cloud & AI Platforms</h2>
        <p class="text-gray-500 text-xs mt-1">Infrastructure frameworks powering our operational and automation layers.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-4 gap-8" data-reveal-group>
        <div class="glass-panel p-8 rounded-xl text-center flex flex-col items-center justify-center min-h-[160px]">
          <!-- Microsoft Azure Logo -->
          <svg class="w-8 h-8 mb-4" viewBox="0 0 23 23" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 0h11v11H0z" fill="#f25022"/>
            <path d="M12 0h11v11H12z" fill="#7fba00"/>
            <path d="M0 12h11v11H0z" fill="#00a4ef"/>
            <path d="M12 12h11v11H12z" fill="#ffb900"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">Microsoft Azure</span>
          <span class="text-gray-500 text-[10px] uppercase font-bold tracking-widest mt-1">Cloud Platform</span>
        </div>
        
        <div class="glass-panel p-8 rounded-xl text-center flex flex-col items-center justify-center min-h-[160px]">
          <!-- AWS Logo -->
          <svg class="w-12 h-8 mb-4" viewBox="0 0 32 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="13" fill="white" font-weight="bold" font-family="sans-serif" font-size="12">aws</text>
            <path d="M2 15c4 3 16 3 20 0" stroke="#ff9900" stroke-width="1.5" stroke-linecap="round" />
            <path d="M18 14.5l2 1-1.5-2.5" stroke="#ff9900" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="text-white font-display font-bold text-sm">Amazon Web Services</span>
          <span class="text-gray-500 text-[10px] uppercase font-bold tracking-widest mt-1">Cloud Partner</span>
        </div>

        <div class="glass-panel p-8 rounded-xl text-center flex flex-col items-center justify-center min-h-[160px]">
          <!-- Google Cloud Logo -->
          <svg class="w-8 h-8 mb-4" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" fill="#4285F4"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">Google Cloud</span>
          <span class="text-gray-500 text-[10px] uppercase font-bold tracking-widest mt-1">Core Architect</span>
        </div>

        <div class="glass-panel p-8 rounded-xl text-center flex flex-col items-center justify-center min-h-[160px]">
          <!-- Anthropic Claude Logo -->
          <svg class="w-8 h-8 mb-4 text-amber-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 22h4l2.5-5.5h7l2.5 5.5h4L12 2zm1 12H11l1-3 1 3z" fill="currentColor"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">Anthropic Claude</span>
          <span class="text-gray-500 text-[10px] uppercase font-bold tracking-widest mt-1">AI Workflow Support</span>
        </div>
      </div>
    </div>

    <!-- Category 2: Security Platforms -->
    <div class="max-w-7xl mx-auto mb-20">
      <div class="border-b border-white/5 pb-4 mb-8">
        <h2 class="text-xl font-display font-bold text-white uppercase tracking-wider">Security Alliances</h2>
        <p class="text-gray-500 text-xs mt-1">Enterprise endpoint detection, access control, and vulnerability management.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-6" data-reveal-group>
        <div class="glass-panel p-6 rounded-xl text-center flex flex-col items-center justify-center">
          <!-- SentinelOne -->
          <svg class="w-8 h-8 mb-3 text-purple-500" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7v8c0 5.25 4.25 9.5 10 11 5.75-1.5 10-5.75 10-11V7L12 2z" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="12" cy="12" r="3" fill="currentColor"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">SentinelOne</span>
          <span class="text-gray-500 text-[8px] uppercase tracking-wider mt-1">Endpoint Security</span>
        </div>

        <div class="glass-panel p-6 rounded-xl text-center flex flex-col items-center justify-center">
          <!-- Zscaler -->
          <svg class="w-8 h-8 mb-3 text-sky-500" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L4 7v10l8 5 8-5V7l-8-5zm-2 11l4-4M10 9l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">Zscaler</span>
          <span class="text-gray-500 text-[8px] uppercase tracking-wider mt-1">ZTNA Partner</span>
        </div>

        <div class="glass-panel p-6 rounded-xl text-center flex flex-col items-center justify-center">
          <!-- Abnormal Security -->
          <svg class="w-8 h-8 mb-3 text-red-500" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="2"/>
            <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">Abnormal</span>
          <span class="text-gray-500 text-[8px] uppercase tracking-wider mt-1">Email Defense</span>
        </div>

        <div class="glass-panel p-6 rounded-xl text-center flex flex-col items-center justify-center">
          <!-- Qualys -->
          <svg class="w-8 h-8 mb-3 text-red-600" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="11" r="6" stroke="currentColor" stroke-width="2.5"/>
            <path d="M16 15l3 3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span class="text-white font-display font-bold text-sm">Qualys</span>
          <span class="text-gray-500 text-[8px] uppercase tracking-wider mt-1">Vulnerability Core</span>
        </div>

        {[
          ['Sublime', 'text-cyan-400'],
          ['Proofpoint', 'text-rose-400'],
          ['CrowdStrike', 'text-red-500'],
        ].map(([partner, color]) => (
          <div class="glass-panel p-6 rounded-xl text-center flex flex-col items-center justify-center">
            <svg class={`w-8 h-8 mb-3 ${color}`} viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2L4 6v5c0 5.25 3.4 9.4 8 11 4.6-1.6 8-5.75 8-11V6l-8-4z" stroke="currentColor" stroke-width="2"/>
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-white font-display font-bold text-sm">{partner}</span>
            <span class="text-gray-500 text-[8px] uppercase tracking-wider mt-1">Security Partner</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Marketplace Callout -->
    <div class="max-w-4xl mx-auto text-center bg-black/40 border border-white/5 rounded-2xl p-8 lg:p-12 relative overflow-hidden" data-reveal>
      <div class="absolute -top-12 -left-12 w-48 h-48 rounded-full bg-indigo-500/5 blur-3xl"></div>
      <h3 class="text-2xl font-display font-bold text-white mb-4">Curated Cybersecurity Marketplace</h3>
      <p class="text-gray-400 text-xs max-w-xl mx-auto leading-relaxed mb-6">
        Aetas can help evaluate, procure, and configure selected cybersecurity tools. Specific reseller status, pricing, savings, and partner tiers are confirmed during scoping before they are represented publicly.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/contact?intent=general" class="px-8 py-3.5 rounded-lg text-xs font-semibold bg-white text-black hover:bg-white/90 transition-all">
          Request Vendor Catalog
        </a>
        <a href="/contact?intent=general" class="px-8 py-3.5 rounded-lg text-xs font-semibold bg-white/5 hover:bg-white/10 text-white transition-all border border-white/10">
          Become a Partner
        </a>
      </div>
    </div>
  </section>
</Layout>
