---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Request Received" description="Thank you for contacting Aetas.ai.">
  <section class="py-24 px-6 max-w-3xl mx-auto text-center">
    <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest">Request Received</span>
    <h1 class="text-4xl sm:text-5xl font-display font-bold text-white mt-3">Thank you for contacting Aetas.</h1>
    <p class="text-gray-400 text-sm sm:text-base leading-relaxed mt-5">
      Your request has been routed. The next step is a focused conversation about your security, managed operations, partner, or AI early-access needs.
    </p>
    <a href="/" class="inline-flex mt-8 px-8 py-4 rounded-xl font-bold bg-white text-black hover:bg-white/90 transition-all">
      Return home
    </a>
  </section>
</Layout>
