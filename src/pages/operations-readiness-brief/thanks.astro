---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AGI Brief Ready" description="Download the AGI Operations Readiness Brief from Aetas Global Innovation." noIndex>
  <section class="px-6 py-24">
    <div class="mx-auto max-w-4xl text-center">
      <span class="text-xs font-bold uppercase tracking-widest text-emerald-300">Download Ready</span>
      <h1 class="mt-4 text-4xl font-display font-bold text-white sm:text-6xl">
        Your AGI Operations Readiness Brief is ready.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-sm leading-relaxed text-gray-400">
        Use this brief to align your team around automation opportunities, security requirements, IT operations, and BPO/helpdesk workflows before a deeper scoping conversation.
      </p>

      <div class="mt-10 rounded-3xl border border-white/10 bg-white/[0.035] p-6 text-left sm:p-8">
        <h2 class="text-2xl font-display font-bold text-white">Brief Summary</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {[
            ['1. Workflow inventory', 'List the repetitive, high-volume, or slow-moving work that could benefit from AI assistance.'],
            ['2. Human validation', 'Define which outputs need review before customer, system, security, or policy impact.'],
            ['3. Operating signals', 'Connect support queues, identity events, endpoint alerts, and reporting into one service view.'],
            ['4. Implementation path', 'Start with a controlled service engagement, measure results, and expand where impact is clear.'],
          ].map(([title, body]) => (
            <article class="rounded-2xl border border-white/8 bg-black/25 p-5">
              <h3 class="font-display font-bold text-white">{title}</h3>
              <p class="mt-3 text-xs leading-relaxed text-gray-400">{body}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/contact?intent=ai" class="w-full rounded-xl bg-white px-8 py-4 text-center font-bold text-black transition-all hover:bg-white/90 sm:w-auto">
          Discuss with AGI
        </a>
        <a href="/resources" class="w-full rounded-xl border border-white/10 bg-white/[0.035] px-8 py-4 text-center font-bold text-white transition-all hover:bg-white/[0.06] sm:w-auto">
          Browse resources
        </a>
      </div>
    </div>
  </section>
</Layout>
