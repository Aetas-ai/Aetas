---
import Layout from '../layouts/Layout.astro';
import AdvisorQuiz from '../components/AdvisorQuiz';
import ManagedSystems from '../components/ManagedSystems';
import { caseStudies } from '../data/caseStudies';
---

<Layout title="Human-led AI for Security and Operations" description="Aetas.ai combines active security services, managed IT and BPO operations, and an early-access roadmap for human-in-the-loop AI automation.">
  <section class="relative min-h-[88vh] flex items-center overflow-hidden py-20 px-6">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_20%,rgba(99,102,241,0.10)_0,transparent_48%),radial-gradient(circle_at_80%_60%,rgba(14,165,233,0.08)_0,transparent_42%)] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
      <div class="lg:col-span-7 flex flex-col gap-6 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 self-center lg:self-start px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs font-semibold text-indigo-300">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
          <span>Security, managed operations, and human-led AI roadmap</span>
        </div>

        <h1 class="text-4xl sm:text-6xl lg:text-7xl font-display font-bold leading-tight text-white tracking-tight">
          Human-led AI for<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-indigo-400 to-amber-400">
            Security & Operations.
          </span>
        </h1>

        <p class="text-gray-300 text-base sm:text-lg max-w-2xl leading-relaxed">
          Aetas combines active SOC/MDR, managed IT and BPO delivery, and an early-access roadmap for workflow automation that keeps experts in the loop.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center mt-4">
          <a href="/contact" class="w-full sm:w-auto px-8 py-4 rounded-xl font-bold bg-white text-black hover:bg-white/90 transition-all text-center shadow-xl shadow-white/5 hover:scale-[1.02] active:scale-[0.98]">
            Talk to Aetas
          </a>
          <a href="#services" class="w-full sm:w-auto px-8 py-4 rounded-xl font-bold bg-white/5 border border-white/10 text-white hover:bg-white/10 hover:border-white/20 transition-all text-center">
            Explore Services
          </a>
        </div>
      </div>

      <div class="lg:col-span-5" data-reveal-right>
        <div class="glass-panel rounded-3xl p-6 lg:p-8 shadow-2xl border-white/10">
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="rounded-2xl bg-sky-500/10 border border-sky-500/20 p-4">
              <span class="text-2xl font-display font-bold text-white">SOC</span>
              <p class="text-[11px] text-sky-200 mt-1">Managed detection and response</p>
            </div>
            <div class="rounded-2xl bg-amber-500/10 border border-amber-500/20 p-4">
              <span class="text-2xl font-display font-bold text-white">MSP</span>
              <p class="text-[11px] text-amber-100 mt-1">Helpdesk and operations support</p>
            </div>
            <div class="rounded-2xl bg-indigo-500/10 border border-indigo-500/20 p-4 col-span-2">
              <span class="text-2xl font-display font-bold text-white">AI Roadmap</span>
              <p class="text-[11px] text-indigo-100 mt-1">Human-in-the-loop workflow automation in development</p>
            </div>
          </div>
          <div class="space-y-3 text-xs text-gray-300">
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-sky-400"></span> Security events and endpoint signals</div>
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-amber-400"></span> Identity, device, and support queues</div>
            <div class="flex items-center gap-3"><span class="w-2 h-2 rounded-full bg-indigo-400"></span> AI-assisted drafts reviewed by specialists</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-white/5 py-10 bg-black/20 overflow-hidden">
    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest text-center mb-5">
      Technology ecosystem used across security, cloud, support, and automation workflows
    </p>
    <div class="partnership-marquee flex overflow-hidden relative w-full">
      {Array.from({ length: 2 }).map(() => (
        <div class="animate-marquee flex gap-16 items-center whitespace-nowrap text-lg text-gray-500 font-bold font-display select-none" aria-hidden="true">
          <span>MICROSOFT CLOUD</span>
          <span>AMAZON WEB SERVICES</span>
          <span>GOOGLE CLOUD</span>
          <span>ANTHROPIC CLAUDE</span>
          <span>SENTINELONE</span>
          <span>ZSCALER</span>
          <span>ABNORMAL SECURITY</span>
          <span>QUALYS</span>
          <span>VULCAN CYBER</span>
          <span>LIGHTSTREAM</span>
        </div>
      ))}
    </div>
  </section>

  <section id="services" class="py-24 px-6 max-w-7xl mx-auto scroll-mt-24">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mb-4">Three Disciplines. One Operating Model.</h2>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed">
        Security and Global are active services. AI is the roadmap layer being built around the operational reality those teams already know.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      <article class="glass-panel glass-panel-hover rounded-2xl p-8 flex flex-col justify-between">
        <div>
          <span class="px-3 py-1 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 text-[10px] font-bold uppercase tracking-wider mb-6 inline-block">In Development</span>
          <h3 class="text-2xl font-display font-bold text-white mb-4">Aetas AI</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">Early-access workflow automation for BPO, support, and operations teams. Built for AI assistance with human validation.</p>
        </div>
        <a href="/ai" class="text-xs font-semibold text-indigo-400 hover:text-indigo-300">Read the roadmap &rarr;</a>
      </article>

      <article class="glass-panel glass-panel-hover rounded-2xl p-8 flex flex-col justify-between">
        <div>
          <span class="px-3 py-1 rounded bg-sky-500/10 text-sky-400 border border-sky-500/20 text-[10px] font-bold uppercase tracking-wider mb-6 inline-block">Active MSSP</span>
          <h3 class="text-2xl font-display font-bold text-white mb-4">Aetas Security</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">Managed detection, SOC support, penetration testing, incident response planning, compliance support, and security tooling.</p>
        </div>
        <a href="/security" class="text-xs font-semibold text-sky-400 hover:text-sky-300">Explore security &rarr;</a>
      </article>

      <article class="glass-panel glass-panel-hover rounded-2xl p-8 flex flex-col justify-between">
        <div>
          <span class="px-3 py-1 rounded bg-amber-500/10 text-amber-500 border border-amber-500/20 text-[10px] font-bold uppercase tracking-wider mb-6 inline-block">Active MSP / BPO</span>
          <h3 class="text-2xl font-display font-bold text-white mb-4">Aetas Global</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">Always-on helpdesk, identity operations, device management, tenant administration, and outsourced support queues.</p>
        </div>
        <a href="/global" class="text-xs font-semibold text-amber-500 hover:text-amber-400">Explore operations &rarr;</a>
      </article>
    </div>
  </section>

  <section class="bg-black/40 border-y border-white/5 py-12 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 items-center text-center">
      <div><span class="text-white font-display font-bold text-xl sm:text-2xl">SOC / MDR</span><span class="block text-gray-500 text-[10px] sm:text-xs uppercase tracking-wider mt-1">Security Operations</span></div>
      <div><span class="text-white font-display font-bold text-xl sm:text-2xl">24/7/365</span><span class="block text-gray-500 text-[10px] sm:text-xs uppercase tracking-wider mt-1">Operational Coverage</span></div>
      <div><span class="text-white font-display font-bold text-xl sm:text-2xl">100+</span><span class="block text-gray-500 text-[10px] sm:text-xs uppercase tracking-wider mt-1">Security Products</span></div>
      <div><span class="text-white font-display font-bold text-xl sm:text-2xl">Early Access</span><span class="block text-gray-500 text-[10px] sm:text-xs uppercase tracking-wider mt-1">AI Roadmap</span></div>
    </div>
  </section>

  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 flex flex-col gap-6" data-reveal>
        <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest">How Aetas Works</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white leading-tight">A steady operating layer for security, IT, and support.</h2>
        <p class="text-gray-400 text-sm leading-relaxed">
          Aetas works with the real flow of enterprise operations: alerts, tickets, identity tasks, endpoint events, and support queues. The model is simple: define ownership, run the process, escalate clearly, and improve the workflow over time.
        </p>
      </div>
      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4" data-reveal-group>
        <article class="glass-panel rounded-2xl p-6">
          <span class="text-[10px] font-bold text-sky-400 uppercase tracking-widest">1. Stabilize</span>
          <h3 class="text-xl font-display font-bold text-white mt-3 mb-3">Map the current environment</h3>
          <p class="text-xs text-gray-400 leading-relaxed">Document systems, queues, risk areas, owners, tooling, and escalation paths before changing the workflow.</p>
        </article>
        <article class="glass-panel rounded-2xl p-6">
          <span class="text-[10px] font-bold text-amber-400 uppercase tracking-widest">2. Operate</span>
          <h3 class="text-xl font-display font-bold text-white mt-3 mb-3">Run the recurring work</h3>
          <p class="text-xs text-gray-400 leading-relaxed">Handle monitoring, helpdesk, identity, device, tenant, and support tasks with clear service boundaries.</p>
        </article>
        <article class="glass-panel rounded-2xl p-6">
          <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest">3. Escalate</span>
          <h3 class="text-xl font-display font-bold text-white mt-3 mb-3">Keep judgment with people</h3>
          <p class="text-xs text-gray-400 leading-relaxed">Route incidents, exceptions, and high-impact changes to trained specialists before action is taken.</p>
        </article>
        <article class="glass-panel rounded-2xl p-6">
          <span class="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">4. Improve</span>
          <h3 class="text-xl font-display font-bold text-white mt-3 mb-3">Identify automation candidates</h3>
          <p class="text-xs text-gray-400 leading-relaxed">Use operational patterns to find future AI-assisted workflows while keeping validation and accountability intact.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="systems-we-manage" class="py-24 px-6 max-w-7xl mx-auto scroll-mt-24 border-t border-white/5">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mb-4">Systems We Manage & Configure</h2>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed">Explore the identity, device, security, and productivity tasks Aetas Global and Aetas Security can manage for client tenants.</p>
    </div>
    <ManagedSystems client:load />
  </section>

  <section class="py-24 px-6 bg-black/20 border-y border-white/5 relative">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 flex flex-col gap-6" data-reveal>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white leading-tight">Which Aetas team fits your need?</h2>
        <p class="text-gray-400 text-sm leading-relaxed">Use the advisor to route your request toward Security, Global operations, or AI early access without guessing where to start.</p>
      </div>
      <div class="lg:col-span-7" data-reveal>
        <AdvisorQuiz client:load />
      </div>
    </div>
  </section>

  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mb-4">Selected Work</h2>
      <p class="text-gray-400 text-sm leading-relaxed">Anonymized examples of active Security and Global work. AI case studies will be added after production pilots exist.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      {caseStudies.slice(0, 3).map((study) => (
        <article class="glass-panel rounded-2xl p-6 flex flex-col justify-between">
          <div>
            <span class="text-3xl font-display font-bold text-white block mb-1">{study.metric}</span>
            <span class="text-xs text-gray-500 block mb-5">{study.metricLabel}</span>
            <h3 class="font-display font-bold text-white text-lg mb-3">{study.title}</h3>
            <p class="text-gray-400 text-xs leading-relaxed">{study.summary}</p>
          </div>
          <a href={`/work/${study.slug}`} class="mt-6 text-xs font-semibold text-indigo-300 hover:text-white transition-colors">Read case study &rarr;</a>
        </article>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-4xl mx-auto text-center flex flex-col gap-6 items-center" data-reveal>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white">Build a more resilient operating layer.</h2>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed max-w-2xl">
        Talk to Aetas about securing infrastructure, scaling managed support, or shaping an early human-led AI workflow pilot.
      </p>
      <a href="/contact" class="px-8 py-4 rounded-xl font-bold bg-white text-black hover:bg-white/90 transition-all shadow-xl shadow-white/5 hover:scale-[1.02] active:scale-[0.98]">
        Start a conversation
      </a>
    </div>
  </section>
</Layout>
