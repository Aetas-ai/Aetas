---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Work & Case Studies" description="Approved Aetas Global Innovation case studies will be published here as they become available.">
  <PageHero
    eyebrow="Client work"
    title="Case studies are being prepared for publication."
    description="This page will feature verified, client-approved examples from Aetas AI, Aetas Security, and Aetas Global. We do not publish unverified results or placeholder performance claims."
    compact
  />

  <section class="mx-auto max-w-7xl px-6 py-20 sm:py-24">
    <div class="grid gap-px overflow-hidden border border-white/10 bg-white/10 sm:grid-cols-3" data-reveal-group>
      <div class="min-h-56 bg-brand-bg p-7">
        <span class="text-[10px] font-bold uppercase text-indigo-400">Aetas AI</span>
        <h2 class="mt-4 text-xl font-display font-bold text-white">Workflow automation</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">Approved case study coming soon.</p>
      </div>
      <div class="min-h-56 bg-brand-bg p-7">
        <span class="text-[10px] font-bold uppercase text-sky-400">Aetas Security</span>
        <h2 class="mt-4 text-xl font-display font-bold text-white">Cybersecurity services</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">Approved case study coming soon.</p>
      </div>
      <div class="min-h-56 bg-brand-bg p-7">
        <span class="text-[10px] font-bold uppercase text-amber-400">Aetas Global</span>
        <h2 class="mt-4 text-xl font-display font-bold text-white">Managed operations</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">Approved case study coming soon.</p>
      </div>
    </div>

    <div class="mt-10 flex justify-center" data-reveal>
      <a href="/contact" class="inline-flex min-h-12 items-center justify-center rounded-lg bg-white px-7 py-3 text-sm font-bold text-black transition-colors hover:bg-gray-100">
        Discuss your requirements
      </a>
    </div>
  </section>
</Layout>
