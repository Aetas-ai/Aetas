---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Work & Case Studies" description="Approved Aetas Global Innovation case studies will be published here as they become available.">
  <PageHero
    eyebrow="Client work"
    title="Case studies are being prepared for publication."
    description="This page will feature verified, client-approved examples across AGI AI and automation, cybersecurity, and managed IT services. We do not publish unverified results or placeholder performance claims."
    compact
  />

  <section class="section-light-muted mx-auto max-w-7xl px-6 py-20 sm:py-24">
    <div class="grid gap-5 sm:grid-cols-3" data-reveal-group>
      <div class="editorial-card service-card-ai min-h-56 p-7">
        <span class="text-[10px] font-bold uppercase text-indigo-700">AI &amp; Automation</span>
        <h2 class="mt-4 text-xl font-display font-bold text-white">Workflow automation</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">Approved case study coming soon.</p>
      </div>
      <div class="editorial-card service-card-security min-h-56 p-7">
        <span class="text-[10px] font-bold uppercase text-sky-700">Cybersecurity</span>
        <h2 class="mt-4 text-xl font-display font-bold text-white">Cybersecurity services</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">Approved case study coming soon.</p>
      </div>
      <div class="editorial-card service-card-managed min-h-56 p-7">
        <span class="text-[10px] font-bold uppercase text-amber-800">Managed IT</span>
        <h2 class="mt-4 text-xl font-display font-bold text-white">Managed IT and support</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">Approved case study coming soon.</p>
      </div>
    </div>

    <div class="mt-10 flex justify-center" data-reveal>
      <a href="/contact" class="button-on-light-primary inline-flex min-h-12 items-center justify-center rounded-lg px-7 py-3 text-sm font-bold transition-colors">
        Discuss your requirements
      </a>
    </div>
  </section>
</Layout>
