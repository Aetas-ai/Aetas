---
import Layout from '../layouts/Layout.astro';
import { caseStudies } from '../data/caseStudies';

const pillarStyles = {
  security: 'bg-sky-500/10 text-sky-400 border-sky-500/20',
  global: 'bg-amber-500/10 text-amber-500 border-amber-500/20',
};
---

<Layout title="Work & Case Studies" description="Explore anonymized examples of Aetas Security and Aetas Global work across cybersecurity, managed IT, and BPO operations.">
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="max-w-3xl mb-16">
      <span class="text-xs font-bold text-indigo-400 uppercase tracking-widest">Operational Proof</span>
      <h1 class="text-4xl sm:text-6xl font-display font-bold text-white tracking-tight mt-3">Selected Work</h1>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed mt-5">
        Anonymized examples of how Aetas supports security monitoring, testing, helpdesk operations, BPO delivery, and workflow improvement.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-reveal-group>
      {caseStudies.map((study) => (
        <article class="glass-panel glass-panel-hover rounded-2xl p-7 flex flex-col justify-between min-h-[360px]">
          <div>
            <div class="flex items-start justify-between gap-4 mb-8">
              <span class={`px-3 py-1 rounded-md border text-[10px] font-bold uppercase tracking-wider ${pillarStyles[study.pillar]}`}>
                {study.capability}
              </span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500">
                Aetas {study.pillar === 'security' ? 'Security' : 'Global'}
              </span>
            </div>

            <div class="mb-7">
              <span class="block text-4xl font-display font-bold text-white">{study.metric}</span>
              <span class="text-xs text-gray-400">{study.metricLabel}</span>
            </div>

            <h2 class="text-2xl font-display font-bold text-white mb-4">{study.title}</h2>
            <p class="text-sm text-gray-400 leading-relaxed">{study.summary}</p>
          </div>

          <a href={`/work/${study.slug}`} class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-white hover:text-indigo-300 transition-colors">
            Read case study
            <span aria-hidden="true">&rarr;</span>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
