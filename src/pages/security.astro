---
import Layout from '../layouts/Layout.astro';
import CoManagementHub from '../components/CoManagementHub';
import { caseStudies } from '../data/caseStudies';

const securityStudies = caseStudies.filter((study) => study.pillar === 'security');
---

<Layout title="Aetas Security - MSSP, SOC, MDR, and Pentesting" activePillar="security" description="Aetas Security provides managed detection, SOC support, penetration testing, incident response planning, compliance support, and security tool procurement.">
  <section class="relative min-h-[82vh] flex items-center py-28 px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/pexels-jplenio-1103970_darkblue.png" alt="Abstract security operations background" class="w-full h-full object-cover object-center scale-105 brightness-[0.24]" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-bg/30 via-brand-bg/90 to-brand-bg"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(14,165,233,0.15)_0,transparent_70%)] pointer-events-none"></div>
    </div>

    <div class="max-w-5xl mx-auto text-center relative z-10 flex flex-col gap-6 items-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-sky-500/10 border border-sky-500/20 text-xs font-semibold text-sky-400 backdrop-blur-md">
        <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
        Aetas Security Operations
      </span>

      <h1 class="text-4xl sm:text-7xl font-display font-bold leading-tight text-white tracking-tight">
        Managed security for<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-blue-400 to-indigo-400">always-on operations.</span>
      </h1>

      <p class="text-gray-300 text-base sm:text-xl max-w-3xl leading-relaxed">
        Aetas Security helps organizations monitor threats, test defenses, respond to incidents, and manage security tools with human analyst oversight.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-6 w-full sm:w-auto">
        <a href="#services" class="px-8 py-4 rounded-xl font-bold bg-sky-500 hover:bg-sky-600 text-white shadow-xl shadow-sky-500/20 active:scale-95 transition-all text-center">Explore Services</a>
        <a href="/contact?intent=security" class="px-8 py-4 rounded-xl font-bold bg-white/5 border border-white/10 text-white hover:bg-white/10 active:scale-95 transition-all text-center backdrop-blur-sm">Request Scoping Call</a>
      </div>
    </div>
  </section>

  <section id="services" class="py-24 px-6 max-w-7xl mx-auto scroll-mt-24">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Security Services</span>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">Practical security coverage, not vague promises.</h2>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed mt-4">
        The Security pillar focuses on live analyst workflow, testing, response readiness, and security platform management.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      {[
        ['SOC / MDR Monitoring', 'Alert triage, endpoint and identity signal review, severity routing, and documented escalation.'],
        ['Penetration Testing', 'Network, web application, API, and mobile testing with remediation-focused reporting.'],
        ['Incident Response Planning', 'Containment planning, communication paths, tabletop readiness, and post-incident review.'],
        ['Vulnerability Management', 'Scanning, prioritization, remediation tracking, and recurring exposure review.'],
        ['Security Tool Procurement', 'Reseller and co-management support for selected security platforms.'],
        ['Compliance Support', 'Evidence organization and control-readiness support for audit and regulatory conversations.'],
      ].map(([title, copy]) => (
        <article class="glass-panel p-8 rounded-2xl hover:border-sky-500/30 transition-all duration-300">
          <h3 class="text-xl font-display font-bold text-white mb-4">{title}</h3>
          <p class="text-gray-400 text-xs leading-relaxed">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 bg-black/20 border-y border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl mx-auto text-center mb-16" data-reveal>
        <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Co-Managed Delivery</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">A clear handoff between client teams and Aetas analysts.</h2>
      </div>
      <CoManagementHub client:load />
    </div>
  </section>

  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 flex flex-col gap-6" data-reveal>
        <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Technology Portfolio</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white leading-tight">Security tools configured around your environment.</h2>
        <p class="text-gray-400 text-sm leading-relaxed">
          Aetas works with a broad security portfolio across endpoint, identity, email, vulnerability management, cloud, and zero-trust access. Partner tiers and certifications should be displayed only after verification.
        </p>
      </div>

      <div class="lg:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-4" data-reveal-group>
        {['Microsoft Defender', 'SentinelOne', 'Zscaler', 'Abnormal Security', 'Qualys', 'Vulcan Cyber'].map((tool) => (
          <div class="glass-panel p-5 rounded-xl text-center text-xs font-bold text-gray-300">{tool}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10" data-reveal>
        <div>
          <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Selected Security Work</span>
          <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">Examples of security outcomes.</h2>
        </div>
        <a href="/work" class="text-sm font-semibold text-sky-300 hover:text-white">View all work &rarr;</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-reveal-group>
        {securityStudies.map((study) => (
          <article class="glass-panel rounded-2xl p-7">
            <span class="text-4xl font-display font-bold text-white">{study.metric}</span>
            <p class="text-xs text-gray-500 mt-1 mb-5">{study.metricLabel}</p>
            <h3 class="text-xl font-display font-bold text-white mb-3">{study.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{study.summary}</p>
            <a href={`/work/${study.slug}`} class="inline-flex mt-6 text-xs font-semibold text-sky-300 hover:text-white">Read case study &rarr;</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
