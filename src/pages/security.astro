---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CoManagementHub from '../components/CoManagementHub';
---

<Layout title="Aetas Security - MSSP, SOC, MDR, and Pentesting" activePillar="security" description="Aetas Security provides managed detection, SOC support, penetration testing, incident response planning, compliance support, and security tool procurement.">
  <PageHero
    eyebrow="Aetas Security / Cybersecurity services"
    title="Turn security signals into clear analyst action."
    description="Aetas Security helps organizations monitor and triage threats, test defenses, prepare for incidents, and manage security tooling through a dedicated cybersecurity service practice led by human judgment."
    accent="security"
    image="/visual-security-ops.png"
    imageAlt="Cybersecurity monitoring and response visualization"
    primaryLabel="Scope security services"
    primaryHref="/contact?intent=security"
    secondaryLabel="Explore security services"
    secondaryHref="#services"
    focusLabel="Aetas Security focus"
    focusItems={['Managed detection and triage', 'Testing and vulnerability management', 'Incident response readiness']}
  />

  <section class="border-b border-white/5 bg-black/20 px-6 py-14 sm:py-16" aria-labelledby="security-alert-workflow">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl" data-reveal>
        <span class="text-xs font-bold uppercase text-sky-300">Example security workflow</span>
        <h2 id="security-alert-workflow" class="mt-3 text-3xl font-display font-bold text-white sm:text-4xl">Defender XDR alert to tracked Jira work.</h2>
        <p class="mt-4 text-base leading-relaxed text-gray-400">
          One workflow Aetas can set up sends an Outlook notification and creates a Jira ticket when Microsoft Defender XDR generates an alert. This gives analysts a visible queue for review, documentation, and escalation. The exact workflow can be adapted to the client environment.
        </p>
      </div>

      <ol class="mt-10 grid gap-4 md:grid-cols-4" data-reveal-group>
        {[
          ['01', 'Microsoft Defender XDR', 'A security detection generates an alert.'],
          ['02', 'Outlook notification', 'The alert notification is delivered to the monitoring mailbox.'],
          ['03', 'Jira ticket', 'A tracked ticket is created with the alert information.'],
          ['04', 'Analyst review', 'An analyst validates the event and follows the agreed escalation process.'],
        ].map(([step, title, body]) => (
          <li class="relative border-t border-sky-400/25 bg-white/[0.025] p-5">
            <span class="text-xs font-bold text-sky-300">{step}</span>
            <h3 class="mt-4 text-lg font-display font-bold text-white">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-400">{body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="services" class="py-24 px-6 max-w-7xl mx-auto scroll-mt-24">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Security Services</span>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">Practical security coverage, not vague promises.</h2>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed mt-4">
        The Security pillar focuses on live analyst workflow, testing, response readiness, and security platform management.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      {[
        ['SOC / MDR Monitoring', 'Alert triage, endpoint and identity signal review, severity routing, and documented escalation.'],
        ['Penetration Testing', 'Network, web application, API, and mobile testing with remediation-focused reporting.'],
        ['Incident Response Planning', 'Containment planning, communication paths, tabletop readiness, and post-incident review.'],
        ['Vulnerability Management', 'Scanning, prioritization, remediation tracking, and recurring exposure review.'],
        ['Security Tool Procurement', 'Reseller and co-management support for selected security platforms.'],
        ['Compliance Support', 'Evidence organization and control-readiness support for audit and regulatory conversations.'],
      ].map(([title, copy]) => (
        <article class="glass-panel p-8 rounded-2xl hover:border-sky-500/30 transition-all duration-300">
          <h3 class="text-xl font-display font-bold text-white mb-4">{title}</h3>
          <p class="text-gray-400 text-xs leading-relaxed">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 bg-black/20 border-y border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl mx-auto text-center mb-16" data-reveal>
        <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Co-Managed Delivery</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">A clear handoff between client teams and Aetas analysts.</h2>
      </div>
      <CoManagementHub client:load />
    </div>
  </section>

  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 flex flex-col gap-6" data-reveal>
        <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Technology Portfolio</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white leading-tight">Security tools configured around your environment.</h2>
        <p class="text-gray-400 text-sm leading-relaxed">
          Aetas works with a broad security portfolio across endpoint, identity, email, vulnerability management, cloud, and zero-trust access. Partner tiers and certifications should be displayed only after verification.
        </p>
      </div>

      <div class="lg:col-span-7" data-reveal-right>
        <div class="overflow-hidden rounded-3xl border border-sky-400/15 bg-white/[0.025] shadow-2xl shadow-sky-950/30">
          <img src="/visual-security-ops.png" alt="SOC monitoring and incident response visualization" class="aspect-video w-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="max-w-7xl mx-auto grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4" data-reveal-group>
      {['Microsoft Defender', 'SentinelOne', 'Zscaler', 'Abnormal Security', 'Qualys', 'Vulcan Cyber'].map((tool) => (
        <div class="glass-panel p-5 rounded-xl text-center text-xs font-bold text-gray-300">{tool}</div>
      ))}
    </div>
  </section>

  <section class="border-t border-white/5 px-6 py-20 sm:py-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-5 text-center" data-reveal>
      <span class="text-xs font-bold uppercase text-sky-400">Talk to Aetas Security</span>
      <h2 class="text-3xl font-display font-bold text-white sm:text-5xl">Scope the security service your environment needs.</h2>
      <p class="max-w-2xl text-sm leading-relaxed text-gray-400">Discuss monitoring workflows, penetration testing, vulnerability management, incident readiness, or security platform support with the Security practice.</p>
      <a href="/contact?intent=security" class="inline-flex min-h-12 items-center justify-center rounded-lg bg-security px-7 py-3 text-sm font-bold text-white transition-colors hover:bg-sky-500">Contact Aetas Security</a>
    </div>
  </section>
</Layout>
