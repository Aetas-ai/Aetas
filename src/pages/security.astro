---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Aetas Security - MXDR and Offensive Security" activePillar="security" description="Aetas Security provides Managed Extended Detection and Response (MXDR), Network Security Testing, and Application Security Testing (Pen Testing).">
  <PageHero
    eyebrow="Aetas Security / Cybersecurity services"
    title="Security services led by experienced professionals."
    description="Aetas Security provides Managed Extended Detection and Response (MXDR) and Offensive Security services through focused monitoring, investigation, response, and security testing."
    accent="security"
    image="/visual-security-ops.webp"
    imageAlt="Cybersecurity monitoring and testing visualization"
    primaryLabel="Scope security services"
    primaryHref="/contact?intent=security"
    secondaryLabel="Explore security services"
    secondaryHref="#services"
    focusLabel="Aetas Security focus"
    focusItems={['Managed Extended Detection and Response (MXDR)', 'Network Security Testing', 'Application Security Testing (Pen Testing)']}
  />

  <section id="services" class="py-24 px-6 max-w-7xl mx-auto scroll-mt-24">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Security Services</span>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">Managed detection and offensive testing.</h2>
      <p class="text-gray-400 text-sm sm:text-base leading-relaxed mt-4">
        The Security practice is organized into Managed Extended Detection and Response (MXDR) and Offensive Security.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      {[
        ['MXDR', 'Managed Extended Detection and Response (MXDR)', 'Continuous detection, investigation, response, and escalation guided by experienced security professionals.'],
        ['Offensive Security', 'Network Security Testing', 'Security testing focused on network exposure, configuration weaknesses, and potential attack paths.'],
        ['Offensive Security', 'Application Security Testing (Pen Testing)', 'Application security testing focused on identifying and documenting security weaknesses.'],
      ].map(([category, title, copy]) => (
        <article class="glass-panel p-8 rounded-2xl hover:border-sky-500/30 transition-all duration-300">
          <span class="text-[10px] font-bold uppercase tracking-widest text-sky-300">{category}</span>
          <h3 class="text-xl font-display font-bold text-white mb-4 mt-3">{title}</h3>
          <p class="text-gray-400 text-xs leading-relaxed">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 bg-black/20 border-y border-white/5">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 flex flex-col gap-6" data-reveal>
        <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Aetas Security</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white leading-tight">Focused coverage across detection, response, and testing.</h2>
        <p class="text-gray-400 text-sm leading-relaxed">
          MXDR supports ongoing security monitoring and response, while Offensive Security evaluates network and application defenses through dedicated testing engagements.
        </p>
      </div>

      <div class="lg:col-span-7" data-reveal-right>
        <div class="overflow-hidden rounded-3xl border border-sky-400/15 bg-white/[0.025] shadow-2xl shadow-sky-950/30">
          <img src="/visual-security-ops.webp" alt="Managed detection and offensive security visualization" class="aspect-video w-full object-cover" loading="lazy" decoding="async" width="1672" height="941" />
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 px-6 py-20 sm:py-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-5 text-center" data-reveal>
      <span class="text-xs font-bold uppercase text-sky-400">Talk to Aetas Security</span>
      <h2 class="text-3xl font-display font-bold text-white sm:text-5xl">Scope the security service your environment needs.</h2>
      <p class="max-w-2xl text-sm leading-relaxed text-gray-400">Discuss Managed Extended Detection and Response (MXDR), Network Security Testing, or Application Security Testing (Pen Testing) with the Security practice.</p>
      <a href="/contact?intent=security" class="inline-flex min-h-12 items-center justify-center rounded-lg bg-security px-7 py-3 text-sm font-bold text-white transition-colors hover:bg-sky-500">Contact Aetas Security</a>
    </div>
  </section>
</Layout>
