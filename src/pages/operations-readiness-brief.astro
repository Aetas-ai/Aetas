---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Download the AGI Operations Readiness Brief" description="Register to download the Aetas Global Innovation brief on Human Led AI, cybersecurity, managed IT, and Business Processes operations.">
  <PageHero
    eyebrow="AGI operations readiness brief"
    title="A practical starting point for your next operations decision."
    description="Register for a concise guide to evaluating AGI services across Business Process AI Assimilation, MXDR, Offensive Security, managed IT, and Business Processes operations."
    accent="security"
    image="/agi-operations-command.webp"
    imageAlt="AGI operations readiness visualization"
    compact
  />

  <section class="section-light px-6 py-20 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-12 lg:items-start">
      <div class="lg:col-span-6">
        <h2 class="text-3xl font-display font-bold text-white sm:text-4xl">What the brief helps you evaluate</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {[
            'Identify automation-ready workflows',
            'Evaluate Expert Human Oversight of AI',
            'Map security and IT operations signals',
            'Prepare a practical AGI implementation conversation',
          ].map((item) => (
            <div class="editorial-card p-4 text-sm font-semibold text-ink">
              {item}
            </div>
          ))}
        </div>

        <div class="media-frame-light mt-8 p-5">
          <img src="/undraw-contract-signed.svg" alt="Download registration illustration" class="mx-auto aspect-[16/9] w-full max-w-md object-contain" loading="lazy" />
        </div>
      </div>

      <div class="lg:col-span-6">
        <div class="glass-panel p-6 sm:p-8">
          <div class="mb-6">
            <h2 class="text-2xl font-display font-bold text-white">Register to download</h2>
            <p class="mt-2 text-sm leading-relaxed text-gray-400">
              Share your details and AGI will connect you with the appropriate specialists if your organization wants to discuss implementation.
            </p>
          </div>

          <form class="form-on-light space-y-4" name="agi-readiness-brief" method="post" data-netlify="true" netlify-honeypot="bot-field" action="/operations-readiness-brief/thanks">
            <input type="hidden" name="form-name" value="agi-readiness-brief" />
            <p class="hidden">
              <label>Do not fill this out: <input name="bot-field" /></label>
            </p>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-gray-500">First Name</label>
                <input name="first-name" required class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-white focus:border-sky-400 focus:outline-none" />
              </div>
              <div>
                <label class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-gray-500">Last Name</label>
                <input name="last-name" required class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-white focus:border-sky-400 focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-gray-500">Work Email</label>
              <input name="email" type="email" required class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-white focus:border-sky-400 focus:outline-none" />
            </div>
            <div>
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-gray-500">Company</label>
              <input name="company" required class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm text-white focus:border-sky-400 focus:outline-none" />
            </div>
            <div>
              <label class="mb-2 block text-[10px] font-bold uppercase tracking-wider text-gray-500">Primary Interest</label>
              <select name="interest" required class="w-full rounded-xl border border-white/10 bg-brand-bg px-4 py-3 text-sm text-white focus:border-sky-400 focus:outline-none">
                <option value="ai">AI workflow automation</option>
                <option value="security">MXDR / Offensive Security</option>
                <option value="global">Managed IT / Business Processes / Help Desk</option>
                <option value="mixed">Multiple service areas</option>
              </select>
            </div>
            <button type="submit" class="button-on-light-primary w-full rounded-lg px-5 py-4 text-sm font-bold transition-all active:scale-[0.98]">
              Get the brief
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
