---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { resources } from '../../data/resources';

const resourceIllustrations = [
  '/undraw-motion-alert.svg',
  '/undraw-data-transfer.svg',
  '/undraw-growth-analytics.svg',
];
---

<Layout title="Intel & Blog — AGI Resources" description="Read perspectives on cyber threat intelligence, IT operations, and AI workflows from Aetas Global Innovation specialists.">
  <PageHero
    eyebrow="Insights and resources"
    title="Practical thinking for modern operations."
    description="Read technical perspectives on cybersecurity, managed IT and support operations, and Human Led AI."
    compact
    primaryLabel="Download the AGI brief"
    primaryHref="/operations-readiness-brief"
  />

  <section class="section-light mx-auto max-w-7xl px-6 py-20 sm:py-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {resources.map((article, index) => (
        <article class="glass-panel glass-panel-hover p-6 flex flex-col justify-between" data-reveal>
          <div>
            <div class="mb-5 rounded-2xl bg-white p-4">
              <img src={resourceIllustrations[index % resourceIllustrations.length]} alt={`${article.category} illustration`} class="aspect-[16/10] w-full object-contain" loading="lazy" />
            </div>
            <span class="px-2.5 py-1 rounded bg-indigo-100 text-indigo-700 border border-indigo-200 text-[9px] font-bold uppercase tracking-wider mb-4 inline-block">{article.category}</span>
            <h2 class="text-xl font-display font-bold text-white mb-3 hover:text-indigo-700 transition-colors">
              <a href={`/resources/${article.slug}`}>{article.title}</a>
            </h2>
            <p class="text-gray-400 text-xs leading-relaxed mb-6">{article.summary}</p>
          </div>
          <div class="border-t border-slate-200 pt-4 flex justify-between items-center text-[10px] text-slate-500">
            <span>By {article.author}</span>
            <span>{article.date}</span>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
