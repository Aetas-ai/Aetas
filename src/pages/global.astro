---
import Layout from '../layouts/Layout.astro';
import ManagedSystems from '../components/ManagedSystems';
import { caseStudies } from '../data/caseStudies';

const globalStudies = caseStudies.filter((study) => study.pillar === 'global');
---

<Layout title="Aetas Global - Managed IT, Helpdesk, and BPO Operations" activePillar="global" description="Aetas Global provides managed IT, helpdesk, identity operations, device management, tenant administration, and outsourced BPO support.">
  <section class="relative py-28 px-6 overflow-hidden border-b border-white/5 min-h-[78vh] flex items-center">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(245,158,11,0.07)_0,transparent_58%)] pointer-events-none"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10 flex flex-col gap-6 items-center">
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-xs font-semibold text-amber-500">
        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
        Aetas Global MSP / BPO
      </span>

      <h1 class="text-4xl sm:text-7xl font-display font-bold leading-tight text-white tracking-tight">
        Managed operations for<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-orange-400">teams that cannot slow down.</span>
      </h1>

      <p class="text-gray-300 text-base sm:text-xl max-w-3xl leading-relaxed">
        Aetas Global supports helpdesk queues, identity tasks, device management, tenant administration, and outsourced support operations for growing teams.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-6 w-full sm:w-auto">
        <a href="#services" class="px-8 py-4 rounded-xl font-bold bg-amber-500 hover:bg-amber-600 text-black shadow-xl shadow-amber-500/20 active:scale-95 transition-all text-center">Explore Operations</a>
        <a href="/contact?intent=global" class="px-8 py-4 rounded-xl font-bold bg-white/5 border border-white/10 text-white hover:bg-white/10 active:scale-95 transition-all text-center">Talk to Global</a>
      </div>
    </div>
  </section>

  <section id="services" class="py-24 px-6 max-w-7xl mx-auto scroll-mt-24">
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
      <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">Managed Operations</span>
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">The recurring work your team needs handled well.</h2>
      <p class="text-gray-400 text-sm leading-relaxed mt-4">
        Global is focused on IT and BPO execution: queues, checklists, user support, tenant administration, and escalation discipline.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      {[
        ['Helpdesk Operations', 'L1-L3 ticket handling, user support, access issues, onboarding, and escalation management.'],
        ['Identity & Access', 'Microsoft 365, Entra ID, Google Workspace, MFA, group membership, and license administration.'],
        ['Device Management', 'Endpoint enrollment, compliance profiles, remote lock/wipe support, and software deployment coordination.'],
        ['Tenant Administration', 'Exchange, SharePoint, Google Drive, collaboration permissions, and recurring configuration upkeep.'],
        ['BPO Support Queues', 'Customer support, product support, QA review, documentation, and operational reporting.'],
        ['Operational Reporting', 'Queue health, response targets, recurring blockers, and improvement opportunities.'],
      ].map(([title, copy]) => (
        <article class="glass-panel p-8 rounded-2xl hover:border-amber-500/30 transition-all duration-300">
          <h3 class="text-xl font-display font-bold text-white mb-4">{title}</h3>
          <p class="text-gray-400 text-xs leading-relaxed">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 bg-black/20 border-y border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16" data-reveal>
        <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">Systems We Operate</span>
        <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">Common workflows Aetas can manage.</h2>
      </div>
      <ManagedSystems client:load />
    </div>
  </section>

  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" data-reveal-group>
      {[
        ['Stabilize', 'Document queues, roles, systems, support boundaries, and escalation rules.'],
        ['Operate', 'Run recurring helpdesk, tenant, device, and support tasks against agreed workflows.'],
        ['Improve', 'Report on blockers, repeat issues, automation candidates, and service quality trends.'],
      ].map(([title, copy], index) => (
        <article class="glass-panel rounded-2xl p-8">
          <span class="text-amber-500 text-xs font-bold uppercase tracking-widest">Step {index + 1}</span>
          <h3 class="text-2xl font-display font-bold text-white mt-3 mb-4">{title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10" data-reveal>
        <div>
          <span class="text-xs font-bold text-amber-500 uppercase tracking-widest">Selected Global Work</span>
          <h2 class="text-3xl sm:text-5xl font-display font-bold text-white mt-3">Examples of operations support.</h2>
        </div>
        <a href="/work" class="text-sm font-semibold text-amber-400 hover:text-white">View all work &rarr;</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-reveal-group>
        {globalStudies.map((study) => (
          <article class="glass-panel rounded-2xl p-7">
            <span class="text-4xl font-display font-bold text-white">{study.metric}</span>
            <p class="text-xs text-gray-500 mt-1 mb-5">{study.metricLabel}</p>
            <h3 class="text-xl font-display font-bold text-white mb-3">{study.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{study.summary}</p>
            <a href={`/work/${study.slug}`} class="inline-flex mt-6 text-xs font-semibold text-amber-400 hover:text-white">Read case study &rarr;</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
