---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Careers - Join Aetas Global Innovation" description="Explore open roles in cybersecurity, IT managed services, Business Processes operations, and AI systems engineering at Aetas Global Innovation.">
  <PageHero
    eyebrow="Careers at AGI"
    title="Build the systems behind modern service delivery."
    description="Explore roles across cybersecurity, managed IT, Business Processes operations, and Human Led AI."
    compact
    primaryLabel="View open roles"
    primaryHref="#open-roles"
  />

  <section id="open-roles" class="scroll-mt-24 px-6 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl space-y-6">
      <div class="glass-panel p-6 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" data-reveal>
        <div>
          <span class="px-2 py-0.5 rounded bg-sky-500/10 text-sky-400 border border-sky-500/20 text-[8px] font-bold uppercase tracking-wider">Cybersecurity</span>
          <h3 class="text-lg font-display font-bold text-white mt-2">Managed Extended Detection and Response Analyst</h3>
          <p class="text-gray-500 text-xs mt-1">Austin, TX (Hybrid) or Manila, PH &bull; Full-time</p>
        </div>
        <a href="/contact" class="px-6 py-2.5 rounded-lg text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white transition-all">
          Apply Now
        </a>
      </div>

      <div class="glass-panel p-6 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" data-reveal>
        <div>
          <span class="px-2 py-0.5 rounded bg-amber-500/10 text-amber-500 border border-amber-500/20 text-[8px] font-bold uppercase tracking-wider">Managed IT</span>
          <h3 class="text-lg font-display font-bold text-white mt-2">IT Systems Administrator</h3>
          <p class="text-gray-500 text-xs mt-1">Manila, Philippines &bull; Full-time (Night Shift)</p>
        </div>
        <a href="/contact" class="px-6 py-2.5 rounded-lg text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white transition-all">
          Apply Now
        </a>
      </div>

      <div class="glass-panel p-6 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" data-reveal>
        <div>
          <span class="px-2 py-0.5 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 text-[8px] font-bold uppercase tracking-wider">AI &amp; Automation</span>
          <h3 class="text-lg font-display font-bold text-white mt-2">Machine Learning Engineer (Workflow Automation)</h3>
          <p class="text-gray-500 text-xs mt-1">Austin, TX &bull; Full-time</p>
        </div>
        <a href="/contact" class="px-6 py-2.5 rounded-lg text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white transition-all">
          Apply Now
        </a>
      </div>
    </div>
  </section>
</Layout>
