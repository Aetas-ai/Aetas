---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Careers — Join Aetas" description="Explore open roles in cybersecurity, IT managed services, and AI systems engineering at Aetas.ai.">
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="text-center max-w-3xl mx-auto mb-16 flex flex-col gap-4 items-center">
      <span class="text-xs font-bold text-indigo-400 uppercase tracking-widest">Join our Team</span>
      <h1 class="text-4xl sm:text-5xl font-display font-bold text-white tracking-tight">Scale Modern Operations</h1>
      <p class="text-gray-400 text-sm max-w-xl leading-relaxed">
        Work with certified security specialists, IT technicians, and AI automation developers across our US and Philippines delivery hubs.
      </p>
    </div>

    <!-- Job list -->
    <div class="max-w-4xl mx-auto space-y-6">
      <div class="glass-panel p-6 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" data-reveal>
        <div>
          <span class="px-2 py-0.5 rounded bg-sky-500/10 text-sky-400 border border-sky-500/20 text-[8px] font-bold uppercase tracking-wider">Aetas Security</span>
          <h3 class="text-lg font-display font-bold text-white mt-2">Security Operations Center (SOC) Analyst</h3>
          <p class="text-gray-500 text-xs mt-1">Austin, TX (Hybrid) or Manila, PH &bull; Full-time</p>
        </div>
        <a href="/contact" class="px-6 py-2.5 rounded-lg text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white transition-all">
          Apply Now
        </a>
      </div>

      <div class="glass-panel p-6 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" data-reveal>
        <div>
          <span class="px-2 py-0.5 rounded bg-amber-500/10 text-amber-500 border border-amber-500/20 text-[8px] font-bold uppercase tracking-wider">Aetas Global</span>
          <h3 class="text-lg font-display font-bold text-white mt-2">IT Systems Administrator</h3>
          <p class="text-gray-500 text-xs mt-1">Manila, Philippines &bull; Full-time (Night Shift)</p>
        </div>
        <a href="/contact" class="px-6 py-2.5 rounded-lg text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white transition-all">
          Apply Now
        </a>
      </div>

      <div class="glass-panel p-6 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4" data-reveal>
        <div>
          <span class="px-2 py-0.5 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 text-[8px] font-bold uppercase tracking-wider">Aetas AI</span>
          <h3 class="text-lg font-display font-bold text-white mt-2">Machine Learning Engineer (Workflow Automation)</h3>
          <p class="text-gray-500 text-xs mt-1">Austin, TX &bull; Full-time</p>
        </div>
        <a href="/contact" class="px-6 py-2.5 rounded-lg text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white transition-all">
          Apply Now
        </a>
      </div>
    </div>
  </section>
</Layout>
