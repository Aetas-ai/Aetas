---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Aetas Global Innovation" description="Contact Aetas Global Innovation about MXDR, Offensive Security, Help Desk as a Service, Product Support as a Service, or Business Process AI Assimilation.">
  <PageHero
    eyebrow="Contact AGI"
    title="Start with the AGI service that fits your need."
    description="Tell us whether you need AI and automation, cybersecurity, Help Desk as a Service, Product Support as a Service, or managed IT. AGI will connect you with the appropriate specialists."
    compact
  />

  <section class="section-light mx-auto max-w-7xl px-6 py-20 sm:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5 flex flex-col gap-8">
        <div class="media-frame-light p-5">
          <img src="/undraw-chatting.svg" alt="Support conversation illustration" class="mx-auto aspect-[16/10] w-full max-w-sm object-contain" loading="eager" />
        </div>

        <div class="space-y-6">
          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">Cybersecurity</h4>
            <p class="text-gray-400 text-xs mt-1">Managed Extended Detection and Response (MXDR), Network Security Testing, and Application Security Testing (Pen Testing).</p>
          </div>

          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">Managed IT</h4>
            <p class="text-gray-400 text-xs mt-1">Help Desk as a Service, Product Support as a Service, managed IT, and Business Processes operations.</p>
          </div>

          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">AI &amp; Automation</h4>
            <p class="text-gray-400 text-xs mt-1">Human Led AI and Business Process AI Assimilation with Expert Human Oversight of AI (Expert in the Loop).</p>
          </div>

          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">Direct Channels</h4>
            <p class="text-gray-400 text-xs mt-1">General inquiries: info@aetasglobal.com</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="glass-panel p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-indigo-500 via-sky-500 to-amber-500 opacity-60"></div>

          <form class="form-on-light space-y-6" name="aetas-contact" method="post" action="/api/forms/contact" data-secure-form novalidate>
            <input type="hidden" name="csrf-token" value="" />
            <p class="form-honeypot" aria-hidden="true">
              <label for="contact-website">Leave this field empty</label>
              <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" maxlength="200" />
            </p>
            <p class="form-status" data-form-status tabindex="-1" hidden></p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="contact-first-name" class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">First Name</label>
                <input id="contact-first-name" name="first-name" type="text" required autocomplete="given-name" maxlength="80" aria-describedby="contact-first-name-error" class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
                <p id="contact-first-name-error" class="form-field-error" data-field-error="first-name" hidden></p>
              </div>
              <div>
                <label for="contact-last-name" class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Last Name</label>
                <input id="contact-last-name" name="last-name" type="text" required autocomplete="family-name" maxlength="80" aria-describedby="contact-last-name-error" class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
                <p id="contact-last-name-error" class="form-field-error" data-field-error="last-name" hidden></p>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="contact-email" class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Work Email</label>
                <input id="contact-email" name="email" type="email" required autocomplete="email" inputmode="email" maxlength="254" aria-describedby="contact-email-error" class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
                <p id="contact-email-error" class="form-field-error" data-field-error="email" hidden></p>
              </div>
              <div>
                <label for="contact-company" class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Company Name</label>
                <input id="contact-company" name="company" type="text" required autocomplete="organization" maxlength="120" aria-describedby="contact-company-error" class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
                <p id="contact-company-error" class="form-field-error" data-field-error="company" hidden></p>
              </div>
            </div>

            <div>
              <label for="intent-select" class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Operational Focus Area</label>
              <select id="intent-select" name="intent" required aria-describedby="contact-intent-error" class="w-full px-4 py-3 rounded-lg bg-brand-bg border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500">
                <option value="security">Cybersecurity (MSSP / MXDR / Offensive Security)</option>
                <option value="managed-it">Managed IT (MSP / Help Desk / Product Support)</option>
                <option value="ai">AI &amp; Automation (Business Process AI Assimilation)</option>
                <option value="general">General Inquiries</option>
              </select>
              <p id="contact-intent-error" class="form-field-error" data-field-error="intent" hidden></p>
            </div>

            <div>
              <label for="contact-message" class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Briefly describe your requirements</label>
              <textarea id="contact-message" name="message" rows="4" required minlength="20" maxlength="3000" aria-describedby="contact-message-error" class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500"></textarea>
              <p id="contact-message-error" class="form-field-error" data-field-error="message" hidden></p>
            </div>

            <button type="submit" class="button-on-light-primary w-full py-4 rounded-lg font-bold text-sm transition-all shadow-lg active:scale-[0.98]">
              Send Request to AGI
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const select = document.getElementById('intent-select') as HTMLSelectElement;
      if (select) {
        const urlParams = new URLSearchParams(window.location.search);
        const intent = urlParams.get('intent');
        const normalizedIntent = intent === 'global' ? 'managed-it' : intent;
        if (normalizedIntent && ['security', 'managed-it', 'ai', 'general'].includes(normalizedIntent)) {
          select.value = normalizedIntent;
        }
      }
    });
  </script>
</Layout>
