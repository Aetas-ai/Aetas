---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Aetas Global Innovation" description="Contact Aetas Global Innovation about MXDR, Offensive Security, Help Desk as a Service, Product Support as a Service, or Business Process AI Assimilation.">
  <PageHero
    eyebrow="Contact AGI"
    title="Start with the AGI service that fits your need."
    description="Tell us whether you need AI and automation, cybersecurity, Help Desk as a Service, Product Support as a Service, or managed IT. AGI will connect you with the appropriate specialists."
    compact
  />

  <section class="section-light mx-auto max-w-7xl px-6 py-20 sm:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5 flex flex-col gap-8">
        <div class="media-frame-light p-5">
          <img src="/undraw-chatting.svg" alt="Support conversation illustration" class="mx-auto aspect-[16/10] w-full max-w-sm object-contain" loading="eager" />
        </div>

        <div class="space-y-6">
          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">Cybersecurity</h4>
            <p class="text-gray-400 text-xs mt-1">Managed Extended Detection and Response (MXDR), Network Security Testing, and Application Security Testing (Pen Testing).</p>
          </div>

          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">Managed IT</h4>
            <p class="text-gray-400 text-xs mt-1">Help Desk as a Service, Product Support as a Service, managed IT, and Business Processes operations.</p>
          </div>

          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">AI &amp; Automation</h4>
            <p class="text-gray-400 text-xs mt-1">Human Led AI and Business Process AI Assimilation with Expert Human Oversight of AI (Expert in the Loop).</p>
          </div>

          <div>
            <h4 class="font-display font-bold text-white text-sm uppercase tracking-wider">Direct Channels</h4>
            <p class="text-gray-400 text-xs mt-1">General inquiries: info@aetasglobal.com</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="glass-panel p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-indigo-500 via-sky-500 to-amber-500 opacity-60"></div>

          <form class="form-on-light space-y-6" name="aetas-contact" method="post" data-netlify="true" netlify-honeypot="bot-field" action="/contact/thanks">
            <input type="hidden" name="form-name" value="aetas-contact" />
            <p class="hidden">
              <label>Do not fill this out: <input name="bot-field" /></label>
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">First Name</label>
                <input name="first-name" type="text" required class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Last Name</label>
                <input name="last-name" type="text" required class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Work Email</label>
                <input name="email" type="email" required class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Company Name</label>
                <input name="company" type="text" required class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500" />
              </div>
            </div>

            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Operational Focus Area</label>
              <select id="intent-select" name="intent" required class="w-full px-4 py-3 rounded-lg bg-brand-bg border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500">
                <option value="security">Cybersecurity (MSSP / MXDR / Offensive Security)</option>
                <option value="managed-it">Managed IT (MSP / Help Desk / Product Support)</option>
                <option value="ai">AI &amp; Automation (Business Process AI Assimilation)</option>
                <option value="general">General Inquiries</option>
              </select>
            </div>

            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Briefly describe your requirements</label>
              <textarea name="message" rows="4" required class="w-full px-4 py-3 rounded-lg bg-white/2 border border-white/10 text-white text-sm focus:outline-none focus:border-indigo-500"></textarea>
            </div>

            <button type="submit" class="button-on-light-primary w-full py-4 rounded-lg font-bold text-sm transition-all shadow-lg active:scale-[0.98]">
              Send Request to AGI
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const select = document.getElementById('intent-select') as HTMLSelectElement;
      if (select) {
        const urlParams = new URLSearchParams(window.location.search);
        const intent = urlParams.get('intent');
        const normalizedIntent = intent === 'global' ? 'managed-it' : intent;
        if (normalizedIntent && ['security', 'managed-it', 'ai', 'general'].includes(normalizedIntent)) {
          select.value = normalizedIntent;
        }
      }
    });
  </script>
</Layout>
