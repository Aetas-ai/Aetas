---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import AboutVisualGallery from '../components/AboutVisualGallery.astro';
---

<Layout
  title="About Aetas Global Innovation | AI, Cybersecurity & Managed IT"
  description="Learn how Aetas Global Innovation provides AI and automation, cybersecurity, and managed IT services through one accountable company."
>
  <PageHero
    eyebrow="About Aetas Global Innovation"
    title="One company for intelligent, secure operations."
    description="AGI provides Human Led AI and automation, cybersecurity, and managed IT services through one company with specialized expertise across each service area."
    accent="neutral"
    image="/visual-about-agi.webp"
    imageAlt="Aetas Global Innovation service network visualization"
    primaryLabel="Explore AGI services"
    primaryHref="/#services"
    secondaryLabel="Talk to AGI"
    secondaryHref="/contact"
  />

  <section class="section-light-muted border-y border-white/5 bg-black/20 px-6 py-20">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-5">
        <span class="text-xs font-bold uppercase tracking-widest text-amber-800">Why the name AGI</span>
        <h2 class="mt-3 text-3xl font-display font-bold leading-tight text-white sm:text-5xl">
          An intentional name with a practical operating focus.
        </h2>
      </div>
      <div class="space-y-5 text-sm leading-relaxed text-gray-400 lg:col-span-7">
        <p>
          Aetas Global Innovation is the company name, and AGI is its acronym. The connection to artificial general intelligence is intentional. For AGI, the name represents a practical focus: applying intelligence responsibly to real business work while keeping people accountable for high-impact decisions.
        </p>
        <p>
          AGI applies Human Led AI with Expert Human Oversight of AI, delivers dedicated cybersecurity services, and operates managed IT, help desk, product support, and Business Processes services. Clients engage one company and receive the specialized expertise their requirement needs.
        </p>
      </div>
    </div>
  </section>

  <AboutVisualGallery />

  <section class="section-light px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-14 max-w-3xl">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-700">AGI Services</span>
        <h2 class="mt-3 text-3xl font-display font-bold text-white sm:text-5xl">Specialized expertise for different operational needs.</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {[
          ['AI & Automation', 'Human Led AI and Business Process AI Assimilation for recurring workflows, with Expert Human Oversight of AI (Expert in the Loop).', '/visual-ai-workflows.webp', 'service-card-ai'],
          ['Cybersecurity', 'MSSP services including Managed Extended Detection and Response (MXDR), Network Security Testing, and Application Security Testing (Pen Testing).', '/visual-security-ops.webp', 'service-card-security'],
          ['Managed IT', 'MSP services including Help Desk as a Service, Product Support as a Service, managed IT, and Business Processes operations.', '/visual-global-ops.webp', 'service-card-managed'],
        ].map(([title, body, image, accentClass]) => (
          <article class:list={['glass-panel overflow-hidden', accentClass]}>
            <img src={image} alt={`${title} service visualization`} width="1440" height="810" class="aspect-video w-full object-cover" loading="lazy" decoding="async" />
            <div class="p-7">
            <h3 class="text-xl font-display font-bold text-white">{title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-gray-400">{body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-dark-raised border-t border-white/5 px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-4">
      {[
        ['Clear service choices', 'AI and automation, cybersecurity, and managed IT are presented as specialized AGI services with clear scopes.'],
        ['Human accountability', 'Human Led AI includes Expert Human Oversight of AI for decisions that affect customers, accounts, systems, or security.'],
        ['Defined ownership', 'Each engagement identifies responsibilities, review points, handoffs, and escalation paths.'],
        ['Scope before delivery', 'Work begins by clarifying the client need, service boundaries, dependencies, and expected outcomes.'],
      ].map(([title, body]) => (
        <article class="rounded-2xl border border-white/8 bg-white/[0.025] p-6">
          <h3 class="font-display text-lg font-bold text-white">{title}</h3>
          <p class="mt-3 text-xs leading-relaxed text-gray-400">{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-light border-t border-white/5 px-6 py-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 text-center">
      <h2 class="text-3xl font-display font-bold text-white sm:text-5xl">Start with the AGI service that matches your need.</h2>
      <p class="max-w-2xl text-sm leading-relaxed text-gray-400">
        Tell us whether your requirement involves Business Process AI Assimilation, cybersecurity, or managed IT and Business Processes operations. AGI will connect you with the specialists best suited to scope it.
      </p>
      <a href="/contact" class="button-on-light-primary rounded-lg px-8 py-4 font-bold transition-all active:scale-[0.98]">
        Talk to AGI
      </a>
    </div>
  </section>
</Layout>
