---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="About Aetas Global Innovation | Three Specialized Practices"
  description="Learn how Aetas Global Innovation delivers three distinct practices: Human Led AI and Business Process AI Assimilation, dedicated cybersecurity services, and managed IT and Business Processes operations."
>
  <PageHero
    eyebrow="About Aetas Global Innovation"
    title="One company. Three specialized practices."
    description="AGI brings together Aetas AI, Aetas Security, and Aetas Global while keeping each service scope distinct: Human Led AI for Business Processes, dedicated cybersecurity services, and managed IT and outsourced operations."
    accent="neutral"
    image="/visual-about-agi.webp"
    imageAlt="Aetas Global Innovation service network visualization"
    primaryLabel="Explore the three practices"
    primaryHref="/#services"
    secondaryLabel="Talk to Aetas"
    secondaryHref="/contact"
  />

  <section class="border-y border-white/5 bg-black/20 px-6 py-20">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-5">
        <span class="text-xs font-bold uppercase tracking-widest text-amber-300">Why the name AGI</span>
        <h2 class="mt-3 text-3xl font-display font-bold leading-tight text-white sm:text-5xl">
          An intentional name with a practical operating focus.
        </h2>
      </div>
      <div class="space-y-5 text-sm leading-relaxed text-gray-400 lg:col-span-7">
        <p>
          Aetas Global Innovation is the company name, and AGI is its acronym. The connection to artificial general intelligence is intentional. For Aetas, the name represents a practical focus: applying intelligence responsibly to real business work while keeping people accountable for high-impact decisions.
        </p>
        <p>
          Aetas AI applies Human Led AI with Expert Human Oversight of AI. Aetas Security provides dedicated cybersecurity services. Aetas Global delivers managed IT, help desk, product support, and Business Processes operations. Each practice keeps its own scope, ownership, and escalation path.
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-14 max-w-3xl">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-300">Specialized Practices</span>
        <h2 class="mt-3 text-3xl font-display font-bold text-white sm:text-5xl">Distinct teams for different operational needs.</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {[
          ['Aetas AI', 'Human Led AI and Business Process AI Assimilation for recurring workflows, with Expert Human Oversight of AI (Expert in the Loop).', '/visual-ai-workflows.webp'],
          ['Aetas Security', 'A dedicated cybersecurity practice for Managed Extended Detection and Response (MXDR), Network Security Testing, and Application Security Testing (Pen Testing).', '/visual-security-ops.webp'],
          ['Aetas Global', 'Help Desk as a Service, Product Support as a Service, managed IT, and Business Processes operations with clear ownership and escalation.', '/visual-global-ops.webp'],
        ].map(([title, body, image]) => (
          <article class="glass-panel overflow-hidden rounded-2xl">
            <img src={image} alt={`${title} service visualization`} width="1440" height="810" class="aspect-video w-full object-cover" loading="lazy" decoding="async" />
            <div class="p-7">
            <h3 class="text-xl font-display font-bold text-white">{title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-gray-400">{body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-4">
      {[
        ['Clear service boundaries', 'AI automation, cybersecurity, and managed operations are scoped and delivered through separate practices.'],
        ['Human accountability', 'Human Led AI includes Expert Human Oversight of AI for decisions that affect customers, accounts, systems, or security.'],
        ['Defined ownership', 'Each engagement identifies responsibilities, review points, handoffs, and escalation paths.'],
        ['Scope before delivery', 'Work begins by clarifying the client need, service boundaries, dependencies, and expected outcomes.'],
      ].map(([title, body]) => (
        <article class="rounded-2xl border border-white/8 bg-white/[0.025] p-6">
          <h3 class="font-display text-lg font-bold text-white">{title}</h3>
          <p class="mt-3 text-xs leading-relaxed text-gray-400">{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 text-center">
      <h2 class="text-3xl font-display font-bold text-white sm:text-5xl">Start with the practice that matches your need.</h2>
      <p class="max-w-2xl text-sm leading-relaxed text-gray-400">
        Tell us whether your requirement is Business Process AI Assimilation, dedicated cybersecurity services, or managed IT and Business Processes operations. We will route it to Aetas AI, Aetas Security, or Aetas Global.
      </p>
      <a href="/contact" class="rounded-xl bg-white px-8 py-4 font-bold text-black transition-all hover:bg-white/90 active:scale-[0.98]">
        Talk to Aetas
      </a>
    </div>
  </section>
</Layout>
