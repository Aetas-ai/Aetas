---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="About Aetas Global Innovation" description="Learn about Aetas Global Innovation and its three distinct practices for AI workflow automation, cybersecurity, and managed IT and BPO operations.">
  <PageHero
    eyebrow="About Aetas Global Innovation"
    title="One company. Three distinct service practices."
    description="AGI is the company behind Aetas AI, Aetas Security, and Aetas Global. Each practice has a separate delivery scope across workflow automation, cybersecurity, and managed IT, helpdesk, and BPO operations."
    accent="neutral"
    image="/visual-about-agi.webp"
    imageAlt="Aetas Global Innovation service network visualization"
    primaryLabel="Explore our services"
    primaryHref="/#services"
    secondaryLabel="Talk to AGI"
    secondaryHref="/contact"
  />

  <section class="border-y border-white/5 bg-black/20 px-6 py-20">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-5">
        <span class="text-xs font-bold uppercase tracking-widest text-amber-300">Why the name AGI</span>
        <h2 class="mt-3 text-3xl font-display font-bold leading-tight text-white sm:text-5xl">
          A company name designed for the AI era.
        </h2>
      </div>
      <div class="space-y-5 text-sm leading-relaxed text-gray-400 lg:col-span-7">
        <p>
          Aetas Global Innovation is the company name. AGI is the acronym, and the connection to artificial general intelligence is intentional: the company is focused on practical intelligence inside real business operations.
        </p>
        <p>
          Our work is not about replacing people with automation. It is about helping teams classify, route, draft, summarize, secure, escalate, and operate with better systems and clearer human accountability.
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mb-14 max-w-3xl">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-300">Company Pillars</span>
        <h2 class="mt-3 text-3xl font-display font-bold text-white sm:text-5xl">One company, three service disciplines.</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {[
          ['Aetas AI', 'AI-augmented workflow automation for BPO, support, helpdesk, and operations teams.', '/visual-ai-workflows.webp'],
          ['Aetas Security', 'Configurable alert workflows such as Defender XDR notifications through Outlook and Jira, plus analyst review, penetration testing, and response planning.', '/visual-security-ops.webp'],
          ['Aetas Global', 'Managed IT, identity operations, device management, tenant administration, and BPO support queues.', '/visual-global-ops.webp'],
        ].map(([title, body, image]) => (
          <article class="glass-panel overflow-hidden rounded-2xl">
            <img src={image} alt={`${title} service visualization`} width="1440" height="810" class="aspect-video w-full object-cover" loading="lazy" decoding="async" />
            <div class="p-7">
            <h3 class="text-xl font-display font-bold text-white">{title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-gray-400">{body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-4">
      {[
        ['Human-reviewed', 'Automation should assist specialists, not silently make high-impact decisions.'],
        ['Operationally grounded', 'We start with real queues, systems, risks, and support workflows.'],
        ['Security-aware', 'Identity, endpoint, access, and escalation controls are part of the operating model.'],
        ['Measurable', 'The work should improve response time, accuracy, routing, visibility, or support throughput.'],
      ].map(([title, body]) => (
        <article class="rounded-2xl border border-white/8 bg-white/[0.025] p-6">
          <h3 class="font-display text-lg font-bold text-white">{title}</h3>
          <p class="mt-3 text-xs leading-relaxed text-gray-400">{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="border-t border-white/5 px-6 py-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 text-center">
      <h2 class="text-3xl font-display font-bold text-white sm:text-5xl">Build with AGI.</h2>
      <p class="max-w-2xl text-sm leading-relaxed text-gray-400">
        Aetas Global Innovation can support AI workflow automation, cybersecurity operations, managed IT, and BPO support.
      </p>
      <a href="/contact" class="rounded-xl bg-white px-8 py-4 font-bold text-black transition-all hover:bg-white/90 active:scale-[0.98]">
        Contact AGI
      </a>
    </div>
  </section>
</Layout>
