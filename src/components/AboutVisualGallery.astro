---
const visuals = [
  { src: '/visual-ai-workflows.webp', label: 'Human Led AI workflows', accent: 'ai' },
  { src: '/visual-security-ops.webp', label: 'Cybersecurity services', accent: 'security' },
  { src: '/visual-global-ops.webp', label: 'Managed operations', accent: 'global' },
  { src: '/visual-about-agi.webp', label: 'Three specialized service areas', accent: 'neutral' },
  { src: '/agi-operations-command.webp', label: 'Defined ownership and review', accent: 'mixed' },
] as const;

const lanes = [
  [visuals[0], visuals[3], visuals[1], visuals[4], visuals[2]],
  [visuals[2], visuals[0], visuals[4], visuals[1], visuals[3]],
  [visuals[1], visuals[4], visuals[2], visuals[3], visuals[0]],
] as const;

const services = [
  { name: 'AI & Automation', href: '/ai', detail: 'Human Led AI', accent: 'ai' },
  { name: 'Cybersecurity', href: '/security', detail: 'MSSP / MXDR / Offensive Security', accent: 'security' },
  { name: 'Managed IT', href: '/managed-it', detail: 'MSP / Help Desk / Product Support', accent: 'global' },
] as const;
---

<section id="about-visual-gallery" class="about-gallery-section scroll-mt-20 border-y border-white/5 bg-black/30 px-6 py-20 sm:py-24" aria-labelledby="about-gallery-title">
  <div class="mx-auto grid max-w-7xl min-w-0 gap-12 lg:grid-cols-12 lg:items-center">
    <div class="min-w-0 lg:col-span-4" data-reveal>
      <span class="text-xs font-bold uppercase tracking-widest text-sky-300">Across AGI</span>
      <h2 id="about-gallery-title" class="mt-3 max-w-xl font-display text-3xl font-bold leading-tight text-white sm:text-5xl">
        One company, viewed across three service areas.
      </h2>
      <p class="mt-5 max-w-lg text-sm leading-relaxed text-gray-400">
        AGI brings AI and automation, cybersecurity, and managed IT expertise into one company. Each service area remains easy to understand, scope, and engage.
      </p>

      <nav class="mt-8 grid gap-px overflow-hidden border border-white/10 bg-white/10" aria-label="Explore AGI services">
        {services.map((service) => (
          <a href={service.href} class:list={['gallery-practice', `gallery-practice-${service.accent}`]}>
            <span>
              <strong>{service.name}</strong>
              <small>{service.detail}</small>
            </span>
            <svg viewBox="0 0 20 20" aria-hidden="true">
              <path d="M4 10h11M11 6l4 4-4 4"></path>
            </svg>
          </a>
        ))}
      </nav>
    </div>

    <div class="gallery-stage min-w-0 lg:col-span-8" data-reveal-right>
      <div class="gallery-frame" aria-hidden="true">
        <div class="gallery-grid"></div>
        <div class="gallery-plane">
          {lanes.map((lane, laneIndex) => (
            <div class:list={['gallery-lane', `gallery-lane-${laneIndex + 1}`]}>
              <div class="gallery-track">
                {[0, 1].map((groupIndex) => (
                  <div class="gallery-group" aria-hidden={groupIndex === 1 ? 'true' : undefined}>
                    {lane.map((visual) => (
                      <figure class:list={['gallery-tile', `gallery-tile-${visual.accent}`]}>
                        <img src={visual.src} alt="" width="1672" height="941" loading="lazy" decoding="async" />
                        <figcaption>{visual.label}</figcaption>
                      </figure>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
        <div class="gallery-axis gallery-axis-top">
          <span>AGI / Operating perspectives</span>
          <span>01—03</span>
        </div>
        <div class="gallery-axis gallery-axis-bottom">
          <i></i><i></i><i></i>
          <span>Specialized services / One AGI</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-gallery-section { min-width: 0; overflow: hidden; }

  .gallery-practice {
    --practice-color: white;
    display: flex;
    min-height: 4.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--color-brand-bg);
    padding: 0.9rem 1rem;
    color: white;
    text-decoration: none;
    transition: background-color 180ms ease;
  }
  .gallery-practice:hover,
  .gallery-practice:focus-visible { background: rgba(255, 255, 255, 0.045); }
  .gallery-practice:focus-visible {
    position: relative;
    z-index: 1;
    outline: 2px solid var(--practice-color);
    outline-offset: -2px;
  }
  .gallery-practice-ai { --practice-color: var(--color-ai); }
  .gallery-practice-security { --practice-color: var(--color-security); }
  .gallery-practice-global { --practice-color: var(--color-global); }
  .gallery-practice strong,
  .gallery-practice small { display: block; }
  .gallery-practice strong { font-family: var(--font-display); font-size: 0.8125rem; }
  .gallery-practice small {
    margin-top: 0.25rem;
    color: rgb(107 114 128);
    font-size: 0.625rem;
    line-height: 1.35;
  }
  .gallery-practice svg {
    width: 1.1rem;
    height: 1.1rem;
    flex: 0 0 auto;
    color: var(--practice-color);
    transition: transform 180ms ease;
  }
  .gallery-practice svg path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }
  .gallery-practice:hover svg,
  .gallery-practice:focus-visible svg { transform: translateX(3px); }

  .gallery-stage {
    position: relative;
    height: clamp(30rem, 49vw, 39rem);
    perspective: 1100px;
  }
  .gallery-frame {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-block: 1px solid rgba(255, 255, 255, 0.09);
    background: #06070a;
    isolation: isolate;
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
  }
  .gallery-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 72px 72px;
  }
  .gallery-plane {
    position: absolute;
    top: -32%;
    left: -8%;
    display: grid;
    width: 116%;
    height: 165%;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.55rem, 1.3vw, 0.9rem);
    transform: rotateX(8deg) rotateY(-6deg) rotateZ(-5deg) scale(1.04);
    transform-style: preserve-3d;
  }
  .gallery-lane { min-width: 0; overflow: hidden; }
  .gallery-track { transform: translate3d(0, 0, 0); will-change: transform; }
  .gallery-lane-1 .gallery-track { animation: gallery-up 34s linear infinite; }
  .gallery-lane-2 .gallery-track { animation: gallery-down 39s linear infinite; }
  .gallery-lane-3 .gallery-track { animation: gallery-up 43s linear infinite -13s; }
  .gallery-group {
    display: flex;
    flex-direction: column;
    gap: clamp(0.55rem, 1.3vw, 0.9rem);
    padding-bottom: clamp(0.55rem, 1.3vw, 0.9rem);
  }
  .gallery-tile {
    --tile-color: rgba(255, 255, 255, 0.28);
    position: relative;
    min-width: 0;
    aspect-ratio: 16 / 10;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-top: 2px solid var(--tile-color);
    border-radius: 0.375rem;
    background: #090a0f;
    box-shadow: 0 15px 38px rgba(0, 0, 0, 0.32);
  }
  .gallery-tile-ai { --tile-color: var(--color-ai); }
  .gallery-tile-security { --tile-color: var(--color-security); }
  .gallery-tile-global { --tile-color: var(--color-global); }
  .gallery-tile-mixed { --tile-color: #a5b4fc; }
  .gallery-tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.78;
    filter: saturate(0.78) contrast(1.08);
    transition: filter 220ms ease, opacity 220ms ease;
  }
  .gallery-tile::after {
    position: absolute;
    inset: 45% 0 0;
    background: linear-gradient(to bottom, transparent, rgba(3, 3, 7, 0.92));
    content: '';
  }
  .gallery-tile figcaption {
    position: absolute;
    right: 0.65rem;
    bottom: 0.55rem;
    left: 0.65rem;
    z-index: 1;
    overflow: hidden;
    color: rgba(255, 255, 255, 0.86);
    font-family: var(--font-display);
    font-size: clamp(0.5rem, 0.85vw, 0.65rem);
    font-weight: 700;
    line-height: 1.3;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .gallery-stage:hover .gallery-track { animation-play-state: paused; }
  .gallery-stage:hover .gallery-tile img { opacity: 0.9; filter: saturate(0.95) contrast(1.04); }

  .gallery-axis {
    position: absolute;
    right: 1rem;
    left: 1rem;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: rgba(156, 163, 175, 0.72);
    font-family: var(--font-display);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .gallery-axis-top { top: 1.1rem; }
  .gallery-axis-bottom { bottom: 1.1rem; justify-content: flex-start; gap: 0.35rem; }
  .gallery-axis-bottom i { width: 1.7rem; height: 2px; }
  .gallery-axis-bottom i:nth-child(1) { background: var(--color-ai); }
  .gallery-axis-bottom i:nth-child(2) { background: var(--color-security); }
  .gallery-axis-bottom i:nth-child(3) { margin-right: 0.4rem; background: var(--color-global); }

  @keyframes gallery-up {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(0, -50%, 0); }
  }
  @keyframes gallery-down {
    from { transform: translate3d(0, -50%, 0); }
    to { transform: translate3d(0, 0, 0); }
  }

  @media (max-width: 767px) {
    .gallery-stage { height: clamp(23rem, 102vw, 31rem); }
    .gallery-plane {
      top: -30%;
      left: -10%;
      width: 120%;
      height: 165%;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
      transform: rotateX(6deg) rotateY(-4deg) rotateZ(-4deg) scale(1.03);
    }
    .gallery-lane-3 { display: none; }
    .gallery-group { gap: 0.55rem; padding-bottom: 0.55rem; }
    .gallery-axis { right: 0.75rem; left: 0.75rem; }
  }

  @media (max-width: 479px) {
    .gallery-tile figcaption { font-size: 0.5rem; }
    .gallery-axis-top span:last-child { display: none; }
    .gallery-axis-bottom span { font-size: 0.5rem; }
    .gallery-axis-bottom i { width: 1.05rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-track { animation: none !important; }
    .gallery-group[aria-hidden='true'] { display: none; }
    .gallery-plane { top: -8%; height: 116%; }
  }
</style>
